  "tetromino_4" "{\"type\":\"voxel\",\"parts\":[{\"xMin\":-1.25,\"xMax\":-0.25,\"yMin\":-0.75,\"yMax\":0.25,\"zMin\":-0.5,\"zMax\":0.5,\"color\":\"#aa4499\"},{\"xMin\":-0.25,\"xMax\":0.75,\"yMin\":-0.75,\"yMax\":0.25,\"zMin\":-0.5,\"zMax\":0.5,\"color\":\"#aa4499\"},{\"xMin\":0.75,\"xMax\":1.75,\"yMin\":-0.75,\"yMax\":0.25,\"zMin\":-0.5,\"zMax\":0.5,\"color\":\"#aa4499\"},{\"xMin\":-1.25,\"xMax\":-0.25,\"yMin\":0.25,\"yMax\":1.25,\"zMin\":-0.5,\"zMax\":0.5,\"color\":\"#aa4499\"}]}" load-model

  "tetromino_5" "{\"type\":\"voxel\",\"parts\":[{\"xMin\":-1.5,\"xMax\":-0.5,\"yMin\":-1.0,\"yMax\":0.0,\"zMin\":-0.5,\"zMax\":0.5,\"color\":\"#cc6677\"},{\"xMin\":-0.5,\"xMax\":0.5,\"yMin\":-1.0,\"yMax\":0.0,\"zMin\":-0.5,\"zMax\":0.5,\"color\":\"#cc6677\"},{\"xMin\":-0.5,\"xMax\":0.5,\"yMin\":0.0,\"yMax\":1.0,\"zMin\":-0.5,\"zMax\":0.5,\"color\":\"#cc6677\"},{\"xMin\":0.5,\"xMax\":1.5,\"yMin\":0.0,\"yMax\":1.0,\"zMin\":-0.5,\"zMax\":0.5,\"color\":\"#cc6677\"}]}" load-model

