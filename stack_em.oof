/*
================================================================================
                                STACK 'EM
================================================================================
A premium 3D visually rendered, 2D grid Tetris clone for the MUIE-Nox client.
Uses LWJGL/OpenGL 3D meshes for visual depth and standard Swing/AWT 2D GUI elements.
*/

// --- Utility Helpers ---

// Modulo helper (a % b)
: mod
  over over / * -
;

: min
  over over < IF pop ELSE swap pop THEN
;

: max
  over over > IF pop ELSE swap pop THEN
;

// Absolute value helper ( |n| )
: abs
  dup 0 < IF 0 swap - THEN
;


