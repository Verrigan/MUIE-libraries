// Write coordinates to the tetromino shape table in the heap
// ( piece rotation block dx dy -- )
: set-piece-coord
  temp_dy ! // dy
  temp_dx ! // dx
  temp_block ! // block
  temp_rotation ! // rotation
  temp_piece ! // piece
  
  // calculate base heap address
  temp_piece @ 32 *
  temp_rotation @ 8 * +
  temp_block @ 2 * +
  temp_base_addr ! // base address
  
  // Store offset shifted by +2 to avoid negative values in heap-!
  temp_dx @ 2 + temp_base_addr @ heap-!
  temp_dy @ 2 + temp_base_addr @ 1 + heap-!
;

// Retrieve coordinates from the tetromino shape table in the heap
// ( piece rotation block -- dx dy )
: get-piece-coord
  temp_block ! // block
  temp_rotation ! // rotation
  temp_piece ! // piece
  
  temp_piece @ 32 *
  temp_rotation @ 8 * +
  temp_block @ 2 * +
  temp_base_addr !
  
  temp_base_addr @ heap-@ 2 -
  temp_base_addr @ 1 + heap-@ 2 -
;

// Helper to copy a piece's rotation coordinates to another rotation slot
// ( piece src_rot dest_rot -- )
: clone-rotation
  temp_dest_rot ! // dest_rot
  temp_src_rot ! // src_rot
  temp_piece_clone ! // piece
  
  0 BEGIN dup 4 < WHILE
    dup temp_block_clone ! // block
    temp_piece_clone @ temp_src_rot @ temp_block_clone @ get-piece-coord
    temp_dy ! // dy
    temp_dx ! // dx
    temp_piece_clone @ temp_dest_rot @ temp_block_clone @ temp_dx @ temp_dy @ set-piece-coord
    1 +
  REPEAT
  pop
;

// --- Tetromino Shape Table Initialization ---

: init-tetromino-table
  
  // Piece 0: I-piece (cyan)
  0 0 0 -1 0 set-piece-coord
  0 0 1  0 0 set-piece-coord
  0 0 2  1 0 set-piece-coord
  0 0 3  2 0 set-piece-coord
  
  0 1 0  0 -1 set-piece-coord
  0 1 1  0 0 set-piece-coord
  0 1 2  0 1 set-piece-coord
  0 1 3  0 2 set-piece-coord
  
  0 0 2 clone-rotation
  0 1 3 clone-rotation
  
  // Piece 1: O-piece (yellow)
  1 0 0  0 0 set-piece-coord
  1 0 1  1 0 set-piece-coord
  1 0 2  0 1 set-piece-coord
  1 0 3  1 1 set-piece-coord
  
  1 0 1 clone-rotation
  1 0 2 clone-rotation
  1 0 3 clone-rotation
  
  // Piece 2: T-piece (magenta)
  2 0 0 -1 0 set-piece-coord
  2 0 1  0 0 set-piece-coord
  2 0 2  1 0 set-piece-coord
  2 0 3  0 1 set-piece-coord
  
  2 1 0  0 -1 set-piece-coord
  2 1 1  0 0 set-piece-coord
  2 1 2  0 1 set-piece-coord
  2 1 3  1 0 set-piece-coord
  
  2 2 0 -1 0 set-piece-coord
  2 2 1  0 0 set-piece-coord
  2 2 2  1 0 set-piece-coord
  2 2 3  0 -1 set-piece-coord
  
  2 3 0  0 -1 set-piece-coord
  2 3 1  0 0 set-piece-coord
  2 3 2  0 1 set-piece-coord
  2 3 3 -1 0 set-piece-coord
  
  // Piece 3: L-piece (orange)
  3 0 0 -1 0 set-piece-coord
  3 0 1  0 0 set-piece-coord
  3 0 2  1 0 set-piece-coord
  3 0 3  1 1 set-piece-coord
  
  3 1 0  0 -1 set-piece-coord
  3 1 1  0 0 set-piece-coord
  3 1 2  0 1 set-piece-coord
  3 1 3 -1 1 set-piece-coord
  
  3 2 0 -1 0 set-piece-coord
  3 2 1  0 0 set-piece-coord
  3 2 2  1 0 set-piece-coord
  3 2 3 -1 -1 set-piece-coord
  
  3 3 0  0 -1 set-piece-coord
  3 3 1  0 0 set-piece-coord
  3 3 2  0 1 set-piece-coord
  3 3 3  1 -1 set-piece-coord
  
  // Piece 4: J-piece (blue)
  4 0 0 -1 0 set-piece-coord
  4 0 1  0 0 set-piece-coord
  4 0 2  1 0 set-piece-coord
  4 0 3 -1 1 set-piece-coord
  
  4 1 0  0 -1 set-piece-coord
  4 1 1  0 0 set-piece-coord
  4 1 2  0 1 set-piece-coord
  4 1 3  1 1 set-piece-coord
  
  4 2 0 -1 0 set-piece-coord
  4 2 1  0 0 set-piece-coord
  4 2 2  1 0 set-piece-coord
  4 2 3  1 -1 set-piece-coord
  
  4 3 0  0 -1 set-piece-coord
  4 3 1  0 0 set-piece-coord
  4 3 2  0 1 set-piece-coord
  4 3 3 -1 -1 set-piece-coord
  
  // Piece 5: S-piece (green)
  5 0 0 -1 0 set-piece-coord
  5 0 1  0 0 set-piece-coord
  5 0 2  0 1 set-piece-coord
  5 0 3  1 1 set-piece-coord
  
  5 1 0  0 1 set-piece-coord
  5 1 1  0 0 set-piece-coord
  5 1 2  1 0 set-piece-coord
  5 1 3  1 -1 set-piece-coord
  
  5 0 2 clone-rotation
  5 1 3 clone-rotation
  
  // Piece 6: Z-piece (red)
  6 0 0  1 0 set-piece-coord
  6 0 1  0 0 set-piece-coord
  6 0 2  0 1 set-piece-coord
  6 0 3 -1 1 set-piece-coord
  
  6 1 0  0 -1 set-piece-coord
  6 1 1  0 0 set-piece-coord
  6 1 2  1 0 set-piece-coord
  6 1 3  1 1 set-piece-coord
  
  6 0 2 clone-rotation
  6 1 3 clone-rotation
;

// --- Grid Storage & Helpers ---

// Get cell value at (x, y, z)
// ( x y z -- val )
: grid-get
  temp_grid_z !
  temp_grid_y !
  temp_grid_x !
  
  temp_grid_x @ 0 <
  temp_grid_x @ grid_w @ >= +
  temp_grid_y @ 0 < +
  temp_grid_y @ grid_d @ >= +
  temp_grid_z @ 0 < +
  temp_grid_z @ grid_h @ >= + IF
    0
  ELSE
    active_grid_id @ temp_grid_x @ temp_grid_y @ temp_grid_z @ gl-grid-get
  THEN
;

// Set cell value at (x, y, z)
// ( x y z val -- )
: grid-set
  temp_grid_val !
  temp_grid_z !
  temp_grid_y !
  temp_grid_x !
  
  temp_grid_x @ 0 <
  temp_grid_x @ grid_w @ >= +
  temp_grid_y @ 0 < +
  temp_grid_y @ grid_d @ >= +
  temp_grid_z @ 0 < +
  temp_grid_z @ grid_h @ >= + IF
    // Out of bounds, ignore
  ELSE
    active_grid_id @ temp_grid_x @ temp_grid_y @ temp_grid_z @ temp_grid_val @ gl-grid-set
  THEN
;

// Clear the grid to empty and allocate/initialize the heap
: init-grid
  20000
  grid_w @ grid_h @ * grid_d @ * +
  dup grid_end_addr !
  grid_w @ 2 + grid_d @ 2 + * +
  heap-alloc
  init-tetromino-table
  
  grid_w @ grid_h @ grid_d @ gl-grid-create active_grid_id !
;

// --- Collision Checking ---

: init-active-piece-offsets
  active_piece_type @ 7 >= IF
    active_piece_type @ 7 == IF
      0 active_dx0 ! 0 active_dy0 ! 0 active_dz0 !
      1 active_dx1 ! 0 active_dy1 ! 0 active_dz1 !
      0 active_dx2 ! 1 active_dy2 ! 0 active_dz2 !
      0 active_dx3 ! 0 active_dy3 ! 1 active_dz3 !
    ELSE
    active_piece_type @ 8 == IF
      0 active_dx0 ! 0 active_dy0 ! 0 active_dz0 !
      1 active_dx1 ! 0 active_dy1 ! 0 active_dz1 !
      0 active_dx2 ! 1 active_dy2 ! 0 active_dz2 !
      0 active_dx3 ! 1 active_dy3 ! 1 active_dz3 !
    ELSE
      0 active_dx0 ! 0 active_dy0 ! 0 active_dz0 !
      1 active_dx1 ! 0 active_dy1 ! 0 active_dz1 !
      0 active_dx2 ! 1 active_dy2 ! 0 active_dz2 !
      0 active_dx3 ! 1 active_dy3 ! -1 active_dz3 !
    THEN THEN
  ELSE
    active_piece_type @ 0 0 get-piece-coord active_dz0 ! active_dx0 ! 0 active_dy0 !
    active_piece_type @ 0 1 get-piece-coord active_dz1 ! active_dx1 ! 0 active_dy1 !
    active_piece_type @ 0 2 get-piece-coord active_dz2 ! active_dx2 ! 0 active_dy2 !
    active_piece_type @ 0 3 get-piece-coord active_dz3 ! active_dx3 ! 0 active_dy3 !
  THEN
;

/// ( x y z dx0 dy0 dz0 dx1 dy1 dz1 dx2 dy2 dz2 dx3 dy3 dz3 -- bool )
: check-collision-with-offsets
  temp_dz3 !
  temp_dy3 !
  temp_dx3 !
  temp_dz2 !
  temp_dy2 !
  temp_dx2 !
  temp_dz1 !
  temp_dy1 !
  temp_dx1 !
  temp_dz0 !
  temp_dy0 !
  temp_dx0 !
  temp_coll_z !
  temp_coll_y !
  temp_coll_x !

  // Backup active offsets
  active_dx0 @ backup_dx0 !
  active_dy0 @ backup_dy0 !
  active_dz0 @ backup_dz0 !
  active_dx1 @ backup_dx1 !
  active_dy1 @ backup_dy1 !
  active_dz1 @ backup_dz1 !
  active_dx2 @ backup_dx2 !
  active_dy2 @ backup_dy2 !
  active_dz2 @ backup_dz2 !
  active_dx3 @ backup_dx3 !
  active_dy3 @ backup_dy3 !
  active_dz3 @ backup_dz3 !

  // Set active offsets to candidates
  temp_dx0 @ active_dx0 !
  temp_dy0 @ active_dy0 !
  temp_dz0 @ active_dz0 !
  temp_dx1 @ active_dx1 !
  temp_dy1 @ active_dy1 !
  temp_dz1 @ active_dz1 !
  temp_dx2 @ active_dx2 !
  temp_dy2 @ active_dy2 !
  temp_dz2 @ active_dz2 !
  temp_dx3 @ active_dx3 !
  temp_dy3 @ active_dy3 !
  temp_dz3 @ active_dz3 !

  // Check collision
  active_grid_id @ temp_coll_x @ temp_coll_y @ temp_coll_z @ gl-grid-check-collision temp_coll_res !

  // Restore active offsets
  backup_dx0 @ active_dx0 !
  backup_dy0 @ active_dy0 !
  backup_dz0 @ active_dz0 !
  backup_dx1 @ active_dx1 !
  backup_dy1 @ active_dy1 !
  backup_dz1 @ active_dz1 !
  backup_dx2 @ active_dx2 !
  backup_dy2 @ active_dy2 !
  backup_dz2 @ active_dz2 !
  backup_dx3 @ active_dx3 !
  backup_dy3 @ active_dy3 !
  backup_dz3 @ active_dz3 !

  temp_coll_res @
;

// ( x y z rotation -- bool )
: check-collision-at
  pop // pop rotation
  temp_coll_z !
  temp_coll_y !
  temp_coll_x !
  active_grid_id @ temp_coll_x @ temp_coll_y @ temp_coll_z @ gl-grid-check-collision
;

// --- Piece Spawning & Locking ---

: get-random-piece-count
  grid_d @ 1 > enable_tetracubes @ 1 == * IF 10 ELSE 7 THEN
;

: next-prng-val
  temp_seed !
  temp_seed @ 48271 *
  2147483647 mod
;

: randomize-starting-pos
  // Generate random X seed using global_seed
  global_seed @ next-prng-val global_seed !
  
  // Map to X coordinate
  grid_w @ 4 > IF
    // Spawn randomly in [2, grid_w - 3]
    2
    global_seed @
    grid_w @ 4 - mod +
    active_piece_x !
  ELSE
    grid_w @ 2 / active_piece_x !
  THEN

  // Generate random Y seed using global_seed
  global_seed @ next-prng-val global_seed !

  // Map to Y coordinate
  grid_d @ 4 > IF
    // Spawn randomly in [2, grid_d - 3]
    2
    global_seed @
    grid_d @ 4 - mod +
    active_piece_y !
  ELSE
    grid_d @ 1 > IF
      grid_d @ 2 / active_piece_y !
    ELSE
      0 active_piece_y !
    THEN
  THEN

  // Z-height
  grid_h @ 1 - active_piece_z !
;

: apply-random-rotations
  global_seed @ next-prng-val global_seed !
  global_seed @ 15 mod 5 + temp_rot_count !
  
  BEGIN temp_rot_count @ 0 > WHILE
    global_seed @ next-prng-val global_seed !
    
    grid_d @ 1 <= IF
      // 2D mode: only Z axis rotation
      rotate-z-plus
    ELSE
      // 3D mode: X, Y, or Z axis rotation
      global_seed @ 3 mod temp_axis !
      temp_axis @ 0 == IF
        rotate-z-plus
      ELSE
      temp_axis @ 1 == IF
        rotate-x-plus
      ELSE
        rotate-y-plus
      THEN THEN
    THEN
    
    temp_rot_count @ 1 - temp_rot_count !
  REPEAT
;

: choose-next-piece-type
  // Step global seed and choose random next piece type
  global_seed @ next-prng-val global_seed !
  global_seed @ get-random-piece-count mod next_piece_type !
;

: spawn-piece
  // Load next piece into active slot
  next_piece_type @ active_piece_type !
  0 active_piece_rot ! // rotation = 0
  randomize-starting-pos
  
  init-active-piece-offsets
  ai_mode @ 0 == IF
    apply-random-rotations
  THEN
  
  // Choose random next piece
  choose-next-piece-type
  
  // Immediately check collision on spawn to determine Game Over
  active_piece_x @ active_piece_y @ active_piece_z @ active_piece_rot @ check-collision-at IF
    1 game_over ! // Set Game Over flag to 1
    "/stackem_gameover " score @ to-str + " " + grid_w @ to-str + " " + grid_h @ to-str + " " + grid_d @ to-str + " " + enable_tetracubes @ to-str + " " + ai_played @ to-str + send-line
  ELSE
    trigger-ai-move
  THEN
;

// Shift all rows above 'y' downward, clearing row grid_h-1
// ( y -- )
// Shift all planes above 'z' downward, clearing plane grid_h-1
// ( z -- )
: clear-and-shift-down
  temp_shift_target_z ! // target z (height)
  
  grid_max_h @ 1 - 0 max grid_max_h !
  1 force_full_scan !
  
  active_grid_id @ temp_shift_target_z @ gl-grid-shift-down
;

// Send highscore update packet back to the server
: save-highscore
  "/setprop me /sys/stackem_highscore " highscore @ to-str + send-line
;

: get-leaderboard-name // ( rank -- name )
  dup 1 == IF pop "[LEADERBOARD_NAME_1]" ELSE
  dup 2 == IF pop "[LEADERBOARD_NAME_2]" ELSE
  dup 3 == IF pop "[LEADERBOARD_NAME_3]" ELSE
  dup 4 == IF pop "[LEADERBOARD_NAME_4]" ELSE
  dup 5 == IF pop "[LEADERBOARD_NAME_5]" ELSE
  dup 6 == IF pop "[LEADERBOARD_NAME_6]" ELSE
  dup 7 == IF pop "[LEADERBOARD_NAME_7]" ELSE
  dup 8 == IF pop "[LEADERBOARD_NAME_8]" ELSE
  dup 9 == IF pop "[LEADERBOARD_NAME_9]" ELSE
  dup 10 == IF pop "[LEADERBOARD_NAME_10]" ELSE
  pop ""
  THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN
;

: get-leaderboard-score // ( rank -- score )
  dup 1 == IF pop [LEADERBOARD_SCORE_1] ELSE
  dup 2 == IF pop [LEADERBOARD_SCORE_2] ELSE
  dup 3 == IF pop [LEADERBOARD_SCORE_3] ELSE
  dup 4 == IF pop [LEADERBOARD_SCORE_4] ELSE
  dup 5 == IF pop [LEADERBOARD_SCORE_5] ELSE
  dup 6 == IF pop [LEADERBOARD_SCORE_6] ELSE
  dup 7 == IF pop [LEADERBOARD_SCORE_7] ELSE
  dup 8 == IF pop [LEADERBOARD_SCORE_8] ELSE
  dup 9 == IF pop [LEADERBOARD_SCORE_9] ELSE
  dup 10 == IF pop [LEADERBOARD_SCORE_10] ELSE
  pop 0
  THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN
;

: get-leaderboard-has-rec // ( rank -- has_rec )
  dup 1 == IF pop [LEADERBOARD_HAS_REC_1] ELSE
  dup 2 == IF pop [LEADERBOARD_HAS_REC_2] ELSE
  dup 3 == IF pop [LEADERBOARD_HAS_REC_3] ELSE
  dup 4 == IF pop [LEADERBOARD_HAS_REC_4] ELSE
  dup 5 == IF pop [LEADERBOARD_HAS_REC_5] ELSE
  dup 6 == IF pop [LEADERBOARD_HAS_REC_6] ELSE
  dup 7 == IF pop [LEADERBOARD_HAS_REC_7] ELSE
  dup 8 == IF pop [LEADERBOARD_HAS_REC_8] ELSE
  dup 9 == IF pop [LEADERBOARD_HAS_REC_9] ELSE
  dup 10 == IF pop [LEADERBOARD_HAS_REC_10] ELSE
  pop 0
  THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN
;


: get-line-clear-multiplier // ( lines -- mult )
  dup 2 == IF pop 3 ELSE
  dup 3 == IF pop 6 ELSE
  dup 4 >= IF pop 10 ELSE
  pop 1
  THEN THEN THEN
;

: count-complete-planes // ( -- count )
  0 temp_lines_cleared !
  0 temp_lines_z !
  
  BEGIN temp_lines_z @ grid_h @ < WHILE
    1 temp_lines_is_full !
    
    0 temp_lines_y !
    BEGIN
      temp_lines_is_full @
      temp_lines_y @ grid_d @ < * WHILE
      0 temp_lines_x !
      BEGIN
        temp_lines_is_full @
        temp_lines_x @ grid_w @ < * WHILE
        temp_lines_x @ temp_lines_y @ temp_lines_z @ grid-get 0 == IF
          0 temp_lines_is_full !
        THEN
        temp_lines_x @ 1 + temp_lines_x !
      REPEAT
      temp_lines_y @ 1 + temp_lines_y !
    REPEAT
    
    temp_lines_is_full @ IF
      temp_lines_cleared @ 1 + temp_lines_cleared !
    THEN
    temp_lines_z @ 1 + temp_lines_z !
  REPEAT
  
  temp_lines_cleared @
;

// Scan the grid for complete lines/planes, clear them, shift down, and update scores
// Scan the grid for complete horizontal planes, clear them, shift down, and update scores
: check-lines
  0 temp_lines_z ! // height (z)
  
  BEGIN temp_lines_z @ grid_h @ < WHILE
    1 temp_lines_is_full ! // is_full = 1
    
    0 temp_lines_y ! // depth (y)
    BEGIN
      temp_lines_is_full @
      temp_lines_y @ grid_d @ < * WHILE
      0 temp_lines_x ! // width (x)
      BEGIN
        temp_lines_is_full @
        temp_lines_x @ grid_w @ < * WHILE
        temp_lines_x @ temp_lines_y @ temp_lines_z @ grid-get 0 == IF
          0 temp_lines_is_full ! // empty cell found, is_full = 0
        THEN
        temp_lines_x @ 1 + temp_lines_x !
      REPEAT
      temp_lines_y @ 1 + temp_lines_y !
    REPEAT
    
    temp_lines_is_full @ IF
      temp_lines_z @ clearing_plane_z !
      0 clearing_timer !
      grid_h @ temp_lines_z ! // Break loop
    ELSE
      temp_lines_z @ 1 + temp_lines_z !
    THEN
  REPEAT
;

// Lock active piece into the static grid
: lock-piece
  active_piece_x @ lock_piece_x !
  active_piece_y @ lock_piece_y !
  active_piece_z @ lock_piece_z !
  active_piece_rot @ lock_piece_rot !
  active_piece_type @ lock_piece_type !
  active_dx0 @ 905 !
  active_dy0 @ 906 !
  active_dz0 @ 907 !
  active_dx1 @ 908 !
  active_dy1 @ 909 !
  active_dz1 @ 910 !
  active_dx2 @ 911 !
  active_dy2 @ 912 !
  active_dz2 @ 913 !
  active_dx3 @ 914 !
  active_dy3 @ 915 !
  active_dz3 @ 916 !
  1 lock_occurred !
  active_piece_x @ active_dx0 @ + temp_lock_x !
  active_piece_y @ active_dy0 @ + temp_lock_y !
  active_piece_z @ active_dz0 @ + temp_lock_z !
  temp_lock_z @ grid_h @ < IF
    temp_lock_x @ temp_lock_y @ temp_lock_z @ active_piece_type @ 1 + update-properties-for-block-change
    temp_lock_z @ grid_max_h @ max grid_max_h !
    temp_lock_z @ plane-count-@ 1 + temp_lock_z @ plane-count-!
    temp_lock_x @ 2 - 0 max search_min_x @ min search_min_x !
    temp_lock_x @ 2 + grid_w @ 1 - min search_max_x @ max search_max_x !
    temp_lock_y @ 2 - 0 max search_min_y @ min search_min_y !
    temp_lock_y @ 2 + grid_d @ 1 - min search_max_y @ max search_max_y !
  THEN
  
  active_piece_x @ active_dx1 @ + temp_lock_x !
  active_piece_y @ active_dy1 @ + temp_lock_y !
  active_piece_z @ active_dz1 @ + temp_lock_z !
  temp_lock_z @ grid_h @ < IF
    temp_lock_x @ temp_lock_y @ temp_lock_z @ active_piece_type @ 1 + update-properties-for-block-change
    temp_lock_z @ grid_max_h @ max grid_max_h !
    temp_lock_z @ plane-count-@ 1 + temp_lock_z @ plane-count-!
    temp_lock_x @ 2 - 0 max search_min_x @ min search_min_x !
    temp_lock_x @ 2 + grid_w @ 1 - min search_max_x @ max search_max_x !
    temp_lock_y @ 2 - 0 max search_min_y @ min search_min_y !
    temp_lock_y @ 2 + grid_d @ 1 - min search_max_y @ max search_max_y !
  THEN
  
  active_piece_x @ active_dx2 @ + temp_lock_x !
  active_piece_y @ active_dy2 @ + temp_lock_y !
  active_piece_z @ active_dz2 @ + temp_lock_z !
  temp_lock_z @ grid_h @ < IF
    temp_lock_x @ temp_lock_y @ temp_lock_z @ active_piece_type @ 1 + update-properties-for-block-change
    temp_lock_z @ grid_max_h @ max grid_max_h !
    temp_lock_z @ plane-count-@ 1 + temp_lock_z @ plane-count-!
    temp_lock_x @ 2 - 0 max search_min_x @ min search_min_x !
    temp_lock_x @ 2 + grid_w @ 1 - min search_max_x @ max search_max_x !
    temp_lock_y @ 2 - 0 max search_min_y @ min search_min_y !
    temp_lock_y @ 2 + grid_d @ 1 - min search_max_y @ max search_max_y !
  THEN
  
  active_piece_x @ active_dx3 @ + temp_lock_x !
  active_piece_y @ active_dy3 @ + temp_lock_y !
  active_piece_z @ active_dz3 @ + temp_lock_z !
  temp_lock_z @ grid_h @ < IF
    temp_lock_x @ temp_lock_y @ temp_lock_z @ active_piece_type @ 1 + update-properties-for-block-change
    temp_lock_z @ grid_max_h @ max grid_max_h !
    temp_lock_z @ plane-count-@ 1 + temp_lock_z @ plane-count-!
    temp_lock_x @ 2 - 0 max search_min_x @ min search_min_x !
    temp_lock_x @ 2 + grid_w @ 1 - min search_max_x @ max search_max_x !
    temp_lock_y @ 2 - 0 max search_min_y @ min search_min_y !
    temp_lock_y @ 2 + grid_d @ 1 - min search_max_y @ max search_max_y !
  THEN
  
  count-complete-planes dup 1 max current_wave_lines !
  check-lines
;

// --- Gameplay Moves ---

: move-left
  active_piece_x @ 1 - active_piece_y @ active_piece_z @ 0 check-collision-at 0 == IF
    active_piece_x @ 1 - active_piece_x !
  THEN
;

: move-right
  active_piece_x @ 1 + active_piece_y @ active_piece_z @ 0 check-collision-at 0 == IF
    active_piece_x @ 1 + active_piece_x !
  THEN
;

: move-forward
  active_piece_x @ active_piece_y @ 1 + active_piece_z @ 0 check-collision-at 0 == IF
    active_piece_y @ 1 + active_piece_y !
  THEN
;

: move-backward
  active_piece_x @ active_piece_y @ 1 - active_piece_z @ 0 check-collision-at 0 == IF
    active_piece_y @ 1 - active_piece_y !
  THEN
;

: rotate-z-plus
  0 temp_rot_success !
  grid_d @ 1 <= IF
    // 2D mode: Rotate in X-Z plane (around Y-axis)
    active_dz0 @ 0 swap - candidate_dx0 ! 0 candidate_dy0 ! active_dx0 @ candidate_dz0 !
    active_dz1 @ 0 swap - candidate_dx1 ! 0 candidate_dy1 ! active_dx1 @ candidate_dz1 !
    active_dz2 @ 0 swap - candidate_dx2 ! 0 candidate_dy2 ! active_dx2 @ candidate_dz2 !
    active_dz3 @ 0 swap - candidate_dx3 ! 0 candidate_dy3 ! active_dx3 @ candidate_dz3 !
  ELSE
    // 3D mode: Rotate in X-Y plane (around Z-axis)
    active_dy0 @ candidate_dx0 ! active_dx0 @ 0 swap - candidate_dy0 ! active_dz0 @ candidate_dz0 !
    active_dy1 @ candidate_dx1 ! active_dx1 @ 0 swap - candidate_dy1 ! active_dz1 @ candidate_dz1 !
    active_dy2 @ candidate_dx2 ! active_dx2 @ 0 swap - candidate_dy2 ! active_dz2 @ candidate_dz2 !
    active_dy3 @ candidate_dx3 ! active_dx3 @ 0 swap - candidate_dy3 ! active_dz3 @ candidate_dz3 !
  THEN
  
  active_piece_x @ active_piece_y @ active_piece_z @
  candidate_dx0 @ candidate_dy0 @ candidate_dz0 @
  candidate_dx1 @ candidate_dy1 @ candidate_dz1 @
  candidate_dx2 @ candidate_dy2 @ candidate_dz2 @
  candidate_dx3 @ candidate_dy3 @ candidate_dz3 @
  check-collision-with-offsets 0 == IF
    candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
    candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
    candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
    candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
    1 temp_rot_success !
  THEN
;

: rotate-z-minus
  0 temp_rot_success !
  grid_d @ 1 <= IF
    // 2D mode: Inverse rotate in X-Z plane
    active_dz0 @ candidate_dx0 ! 0 candidate_dy0 ! active_dx0 @ 0 swap - candidate_dz0 !
    active_dz1 @ candidate_dx1 ! 0 candidate_dy1 ! active_dx1 @ 0 swap - candidate_dz1 !
    active_dz2 @ candidate_dx2 ! 0 candidate_dy2 ! active_dx2 @ 0 swap - candidate_dz2 !
    active_dz3 @ candidate_dx3 ! 0 candidate_dy3 ! active_dx3 @ 0 swap - candidate_dz3 !
  ELSE
    // 3D mode: Inverse rotate in X-Y plane
    active_dy0 @ 0 swap - candidate_dx0 ! active_dx0 @ candidate_dy0 ! active_dz0 @ candidate_dz0 !
    active_dy1 @ 0 swap - candidate_dx1 ! active_dx1 @ candidate_dy1 ! active_dz1 @ candidate_dz1 !
    active_dy2 @ 0 swap - candidate_dx2 ! active_dx2 @ candidate_dy2 ! active_dz2 @ candidate_dz2 !
    active_dy3 @ 0 swap - candidate_dx3 ! active_dx3 @ candidate_dy3 ! active_dz3 @ candidate_dz3 !
  THEN
  
  active_piece_x @ active_piece_y @ active_piece_z @
  candidate_dx0 @ candidate_dy0 @ candidate_dz0 @
  candidate_dx1 @ candidate_dy1 @ candidate_dz1 @
  candidate_dx2 @ candidate_dy2 @ candidate_dz2 @
  candidate_dx3 @ candidate_dy3 @ candidate_dz3 @
  check-collision-with-offsets 0 == IF
    candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
    candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
    candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
    candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
    1 temp_rot_success !
  THEN
;

: rotate-y-plus
  0 temp_rot_success !
  active_dz0 @ 0 swap - candidate_dx0 ! active_dy0 @ candidate_dy0 ! active_dx0 @ candidate_dz0 !
  active_dz1 @ 0 swap - candidate_dx1 ! active_dy1 @ candidate_dy1 ! active_dx1 @ candidate_dz1 !
  active_dz2 @ 0 swap - candidate_dx2 ! active_dy2 @ candidate_dy2 ! active_dx2 @ candidate_dz2 !
  active_dz3 @ 0 swap - candidate_dx3 ! active_dy3 @ candidate_dy3 ! active_dx3 @ candidate_dz3 !
  
  active_piece_x @ active_piece_y @ active_piece_z @
  candidate_dx0 @ candidate_dy0 @ candidate_dz0 @
  candidate_dx1 @ candidate_dy1 @ candidate_dz1 @
  candidate_dx2 @ candidate_dy2 @ candidate_dz2 @
  candidate_dx3 @ candidate_dy3 @ candidate_dz3 @
  check-collision-with-offsets 0 == IF
    candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
    candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
    candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
    candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
    1 temp_rot_success !
  THEN
;

: rotate-y-minus
  0 temp_rot_success !
  active_dz0 @ candidate_dx0 ! active_dy0 @ candidate_dy0 ! active_dx0 @ 0 swap - candidate_dz0 !
  active_dz1 @ candidate_dx1 ! active_dy1 @ candidate_dy1 ! active_dx1 @ 0 swap - candidate_dz1 !
  active_dz2 @ candidate_dx2 ! active_dy2 @ candidate_dy2 ! active_dx2 @ 0 swap - candidate_dz2 !
  active_dz3 @ candidate_dx3 ! active_dy3 @ candidate_dy3 ! active_dx3 @ 0 swap - candidate_dz3 !
  
  active_piece_x @ active_piece_y @ active_piece_z @
  candidate_dx0 @ candidate_dy0 @ candidate_dz0 @
  candidate_dx1 @ candidate_dy1 @ candidate_dz1 @
  candidate_dx2 @ candidate_dy2 @ candidate_dz2 @
  candidate_dx3 @ candidate_dy3 @ candidate_dz3 @
  check-collision-with-offsets 0 == IF
    candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
    candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
    candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
    candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
    1 temp_rot_success !
  THEN
;

: rotate-x-plus
  0 temp_rot_success !
  active_dx0 @ candidate_dx0 ! active_dz0 @ 0 swap - candidate_dy0 ! active_dy0 @ candidate_dz0 !
  active_dx1 @ candidate_dx1 ! active_dz1 @ 0 swap - candidate_dy1 ! active_dy1 @ candidate_dz1 !
  active_dx2 @ candidate_dx2 ! active_dz2 @ 0 swap - candidate_dy2 ! active_dy2 @ candidate_dz2 !
  active_dx3 @ candidate_dx3 ! active_dz3 @ 0 swap - candidate_dy3 ! active_dy3 @ candidate_dz3 !
  
  active_piece_x @ active_piece_y @ active_piece_z @
  candidate_dx0 @ candidate_dy0 @ candidate_dz0 @
  candidate_dx1 @ candidate_dy1 @ candidate_dz1 @
  candidate_dx2 @ candidate_dy2 @ candidate_dz2 @
  candidate_dx3 @ candidate_dy3 @ candidate_dz3 @
  check-collision-with-offsets 0 == IF
    candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
    candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
    candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
    candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
    1 temp_rot_success !
  THEN
;

: rotate-x-minus
  0 temp_rot_success !
  active_dx0 @ candidate_dx0 ! active_dz0 @ candidate_dy0 ! active_dy0 @ 0 swap - candidate_dz0 !
  active_dx1 @ candidate_dx1 ! active_dz1 @ candidate_dy1 ! active_dy1 @ 0 swap - candidate_dz1 !
  active_dx2 @ candidate_dx2 ! active_dz2 @ candidate_dy2 ! active_dy2 @ 0 swap - candidate_dz2 !
  active_dx3 @ candidate_dx3 ! active_dz3 @ candidate_dy3 ! active_dy3 @ 0 swap - candidate_dz3 !
  
  active_piece_x @ active_piece_y @ active_piece_z @
  candidate_dx0 @ candidate_dy0 @ candidate_dz0 @
  candidate_dx1 @ candidate_dy1 @ candidate_dz1 @
  candidate_dx2 @ candidate_dy2 @ candidate_dz2 @
  candidate_dx3 @ candidate_dy3 @ candidate_dz3 @
  check-collision-with-offsets 0 == IF
    candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
    candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
    candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
    candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
    1 temp_rot_success !
  THEN
;

: move-down
  active_piece_x @ active_piece_y @ active_piece_z @ 1 - 0 check-collision-at 0 == IF
    active_piece_z @ 1 - active_piece_z !
    0 // not locked
  ELSE
    lock-piece
    clearing_plane_z @ -1 == IF
      spawn-piece
    THEN
    1 // locked
  THEN
;

// --- AI Mode Helper Routines ---

: rotate-z-plus-no-coll
  grid_d @ 1 <= IF
    // 2D mode: Rotate in X-Z plane (around Y-axis)
    active_dz0 @ 0 swap - candidate_dx0 ! 0 candidate_dy0 ! active_dx0 @ candidate_dz0 !
    active_dz1 @ 0 swap - candidate_dx1 ! 0 candidate_dy1 ! active_dx1 @ candidate_dz1 !
    active_dz2 @ 0 swap - candidate_dx2 ! 0 candidate_dy2 ! active_dx2 @ candidate_dz2 !
    active_dz3 @ 0 swap - candidate_dx3 ! 0 candidate_dy3 ! active_dx3 @ candidate_dz3 !
  ELSE
    // 3D mode: Rotate in X-Y plane (around Z-axis)
    active_dy0 @ candidate_dx0 ! active_dx0 @ 0 swap - candidate_dy0 ! active_dz0 @ candidate_dz0 !
    active_dy1 @ candidate_dx1 ! active_dx1 @ 0 swap - candidate_dy1 ! active_dz1 @ candidate_dz1 !
    active_dy2 @ candidate_dx2 ! active_dx2 @ 0 swap - candidate_dy2 ! active_dz2 @ candidate_dz2 !
    active_dy3 @ candidate_dx3 ! active_dx3 @ 0 swap - candidate_dy3 ! active_dz3 @ candidate_dz3 !
  THEN
  
  candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
  candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
  candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
  candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
;

: rotate-x-plus-no-coll
  active_dx0 @ candidate_dx0 ! active_dz0 @ 0 swap - candidate_dy0 ! active_dy0 @ candidate_dz0 !
  active_dx1 @ candidate_dx1 ! active_dz1 @ 0 swap - candidate_dy1 ! active_dy1 @ candidate_dz1 !
  active_dx2 @ candidate_dx2 ! active_dz2 @ 0 swap - candidate_dy2 ! active_dy2 @ candidate_dz2 !
  active_dx3 @ candidate_dx3 ! active_dz3 @ 0 swap - candidate_dy3 ! active_dy3 @ candidate_dz3 !
  
  candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
  candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
  candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
  candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
;

: rotate-y-plus-no-coll
  active_dz0 @ 0 swap - candidate_dx0 ! active_dy0 @ candidate_dy0 ! active_dx0 @ candidate_dz0 !
  active_dz1 @ 0 swap - candidate_dx1 ! active_dy1 @ candidate_dy1 ! active_dx1 @ candidate_dz1 !
  active_dz2 @ 0 swap - candidate_dx2 ! active_dy2 @ candidate_dy2 ! active_dx2 @ candidate_dz2 !
  active_dz3 @ 0 swap - candidate_dx3 ! active_dy3 @ candidate_dy3 ! active_dx3 @ candidate_dz3 !
  
  candidate_dx0 @ active_dx0 ! candidate_dy0 @ active_dy0 ! candidate_dz0 @ active_dz0 !
  candidate_dx1 @ active_dx1 ! candidate_dy1 @ active_dy1 ! candidate_dz1 @ active_dz1 !
  candidate_dx2 @ active_dx2 ! candidate_dy2 @ active_dy2 ! candidate_dz2 @ active_dz2 !
  candidate_dx3 @ active_dx3 ! candidate_dy3 @ active_dy3 ! candidate_dz3 @ active_dz3 !
;

: apply-ai-rotation // ( rot_idx -- )
  temp_rot_idx !
  init-active-piece-offsets
  
  grid_d @ 1 > IF
    // 3D mode: test 12 combinations
    temp_rot_idx @ 4 / temp_axis !
    temp_rot_idx @ 4 mod temp_z_rot !
    
    temp_axis @ 1 == IF
      rotate-x-plus-no-coll
    ELSE
    temp_axis @ 2 == IF
      rotate-y-plus-no-coll
    THEN THEN
    
    // Now apply Z rotations
    BEGIN temp_z_rot @ 0 > WHILE
      rotate-z-plus-no-coll
      temp_z_rot @ 1 - temp_z_rot !
    REPEAT
  ELSE
    // 2D mode: test 4 Z rotations
    temp_rot_idx @ temp_z_rot !
    BEGIN temp_z_rot @ 0 > WHILE
      rotate-z-plus-no-coll
      temp_z_rot @ 1 - temp_z_rot !
    REPEAT
  THEN
;

: find-landing-z // ( px py -- landing_z_or_minus_1 )
  temp_py !
  temp_px !
  active_grid_id @ temp_px @ temp_py @ gl-grid-find-landing-z
;

: set-sim-piece-in-grid // ( val -- )
  temp_ai_val !
  temp_px @ active_dx0 @ + temp_py @ active_dy0 @ + temp_pz @ active_dz0 @ + temp_ai_val @ grid-set
  temp_px @ active_dx1 @ + temp_py @ active_dy1 @ + temp_pz @ active_dz1 @ + temp_ai_val @ grid-set
  temp_px @ active_dx2 @ + temp_py @ active_dy2 @ + temp_pz @ active_dz2 @ + temp_ai_val @ grid-set
  temp_px @ active_dx3 @ + temp_py @ active_dy3 @ + temp_pz @ active_dz3 @ + temp_ai_val @ grid-set
;

: scan-column-properties // ( x y -- height holes )
  temp_py !
  temp_px !
  
  0 temp_h !
  0 temp_h_found !
  0 temp_h_holes !
  
  grid_h @ temp_z !
  BEGIN temp_z @ 0 > WHILE
    temp_z @ 1 - temp_z !
    temp_px @ temp_py @ temp_z @ grid-get 0 > IF
      temp_h_found @ 0 == IF
        temp_z @ 1 + temp_h !
        1 temp_h_found !
      THEN
    ELSE
      temp_h_found @ IF
        temp_h_holes @ 1 + temp_h_holes !
      THEN
    THEN
  REPEAT
  
  temp_h @ temp_h_holes @
;

: get-column-bumpiness-contribution // ( h x y -- bump )
  temp_py !
  temp_px !
  temp_h !
  0 temp_old_bump !
  
  // Left neighbor
  temp_px @ 1 - 0 >= IF
    temp_h @ temp_px @ 1 - temp_py @ col-height-@ - abs temp_old_bump @ + temp_old_bump !
  THEN
  
  // Right neighbor
  temp_px @ 1 + grid_w @ < IF
    temp_h @ temp_px @ 1 + temp_py @ col-height-@ - abs temp_old_bump @ + temp_old_bump !
  THEN
  
  // Forward/Back neighbor in 3D
  grid_d @ 1 > IF
    temp_py @ 1 - 0 >= IF
      temp_h @ temp_px @ temp_py @ 1 - col-height-@ - abs temp_old_bump @ + temp_old_bump !
    THEN
    temp_py @ 1 + grid_d @ < IF
      temp_h @ temp_px @ temp_py @ 1 + col-height-@ - abs temp_old_bump @ + temp_old_bump !
    THEN
  THEN
  
  temp_old_bump @
;

: update-properties-for-block-change // ( bx by bz val -- )
  temp_val !
  temp_cz !
  temp_cy !
  temp_cx !
  
  // 1. Scan column properties before the change
  temp_cx @ temp_cy @ scan-column-properties temp_old_holes ! temp_old_h !
  
  // 2. Set grid value
  temp_cx @ temp_cy @ temp_cz @ temp_val @ grid-set
  
  // 3. Scan column properties after the change
  temp_cx @ temp_cy @ scan-column-properties temp_new_holes ! temp_new_h !
  
  // 4. Update height sum
  base_height_sum @ temp_old_h @ - temp_new_h @ + base_height_sum !
  
  // 5. Update holes
  base_holes @ temp_old_holes @ - temp_new_holes @ + base_holes !
  
  // 6. Update bumpiness
  temp_old_h @ temp_new_h @ == 0 == IF
    temp_old_h @ temp_cx @ temp_cy @ get-column-bumpiness-contribution temp_old_bump !
    base_bumpiness @ temp_old_bump @ - base_bumpiness !
    
    temp_new_h @ temp_cx @ temp_cy @ col-height-!
    
    temp_new_h @ temp_cx @ temp_cy @ get-column-bumpiness-contribution temp_new_bump !
    base_bumpiness @ temp_new_bump @ + base_bumpiness !
  THEN
;

: place-cand1
  sim_cand1_active @ 0 == IF
    cand1_x @ 0 >= cand1_y @ 0 >= * cand1_z @ 0 >= * cand1_rot @ 0 >= * IF
      active_piece_type @ temp_type !
      temp_backup_type @ active_piece_type !
      cand1_x @ temp_px !
      cand1_y @ temp_py !
      cand1_z @ temp_pz !
      cand1_rot @ apply-ai-rotation
      
      // Update properties and grid block-by-block
      cand1_x @ active_dx0 @ + cand1_y @ active_dy0 @ + cand1_z @ active_dz0 @ + temp_backup_type @ 1 + update-properties-for-block-change
      cand1_x @ active_dx1 @ + cand1_y @ active_dy1 @ + cand1_z @ active_dz1 @ + temp_backup_type @ 1 + update-properties-for-block-change
      cand1_x @ active_dx2 @ + cand1_y @ active_dy2 @ + cand1_z @ active_dz2 @ + temp_backup_type @ 1 + update-properties-for-block-change
      cand1_x @ active_dx3 @ + cand1_y @ active_dy3 @ + cand1_z @ active_dz3 @ + temp_backup_type @ 1 + update-properties-for-block-change
      
      // Update plane counts
      cand1_z @ active_dz0 @ + plane-count-@ 1 + cand1_z @ active_dz0 @ + plane-count-!
      cand1_z @ active_dz1 @ + plane-count-@ 1 + cand1_z @ active_dz1 @ + plane-count-!
      cand1_z @ active_dz2 @ + plane-count-@ 1 + cand1_z @ active_dz2 @ + plane-count-!
      cand1_z @ active_dz3 @ + plane-count-@ 1 + cand1_z @ active_dz3 @ + plane-count-!
      
      1 sim_cand1_active !
      temp_type @ active_piece_type !
      init-active-piece-offsets
    THEN
  THEN
;

: clear-cand1
  sim_cand1_active @ 1 == IF
    cand1_x @ 0 >= cand1_y @ 0 >= * cand1_z @ 0 >= * cand1_rot @ 0 >= * IF
      active_piece_type @ temp_type !
      temp_backup_type @ active_piece_type !
      cand1_x @ temp_px !
      cand1_y @ temp_py !
      cand1_z @ temp_pz !
      cand1_rot @ apply-ai-rotation
      
      // Update properties and grid block-by-block (set to 0)
      cand1_x @ active_dx0 @ + cand1_y @ active_dy0 @ + cand1_z @ active_dz0 @ + 0 update-properties-for-block-change
      cand1_x @ active_dx1 @ + cand1_y @ active_dy1 @ + cand1_z @ active_dz1 @ + 0 update-properties-for-block-change
      cand1_x @ active_dx2 @ + cand1_y @ active_dy2 @ + cand1_z @ active_dz2 @ + 0 update-properties-for-block-change
      cand1_x @ active_dx3 @ + cand1_y @ active_dy3 @ + cand1_z @ active_dz3 @ + 0 update-properties-for-block-change
      
      // Update plane counts
      cand1_z @ active_dz0 @ + plane-count-@ 1 - cand1_z @ active_dz0 @ + plane-count-!
      cand1_z @ active_dz1 @ + plane-count-@ 1 - cand1_z @ active_dz1 @ + plane-count-!
      cand1_z @ active_dz2 @ + plane-count-@ 1 - cand1_z @ active_dz2 @ + plane-count-!
      cand1_z @ active_dz3 @ + plane-count-@ 1 - cand1_z @ active_dz3 @ + plane-count-!
      
      temp_type @ active_piece_type !
      init-active-piece-offsets
    THEN
    0 sim_cand1_active !
  THEN
;

: place-cand2
  sim_cand2_active @ 0 == IF
    cand2_x @ 0 >= cand2_y @ 0 >= * cand2_z @ 0 >= * cand2_rot @ 0 >= * IF
      active_piece_type @ temp_type !
      temp_backup_type @ active_piece_type !
      cand2_x @ temp_px !
      cand2_y @ temp_py !
      cand2_z @ temp_pz !
      cand2_rot @ apply-ai-rotation
      
      // Update properties and grid block-by-block
      cand2_x @ active_dx0 @ + cand2_y @ active_dy0 @ + cand2_z @ active_dz0 @ + temp_backup_type @ 1 + update-properties-for-block-change
      cand2_x @ active_dx1 @ + cand2_y @ active_dy1 @ + cand2_z @ active_dz1 @ + temp_backup_type @ 1 + update-properties-for-block-change
      cand2_x @ active_dx2 @ + cand2_y @ active_dy2 @ + cand2_z @ active_dz2 @ + temp_backup_type @ 1 + update-properties-for-block-change
      cand2_x @ active_dx3 @ + cand2_y @ active_dy3 @ + cand2_z @ active_dz3 @ + temp_backup_type @ 1 + update-properties-for-block-change
      
      // Update plane counts
      cand2_z @ active_dz0 @ + plane-count-@ 1 + cand2_z @ active_dz0 @ + plane-count-!
      cand2_z @ active_dz1 @ + plane-count-@ 1 + cand2_z @ active_dz1 @ + plane-count-!
      cand2_z @ active_dz2 @ + plane-count-@ 1 + cand2_z @ active_dz2 @ + plane-count-!
      cand2_z @ active_dz3 @ + plane-count-@ 1 + cand2_z @ active_dz3 @ + plane-count-!
      
      temp_backup_type @ 1 + set-sim-piece-in-grid
      1 sim_cand2_active !
      temp_type @ active_piece_type !
      init-active-piece-offsets
    THEN
  THEN
;

: clear-cand2
  sim_cand2_active @ 1 == IF
    cand2_x @ 0 >= cand2_y @ 0 >= * cand2_z @ 0 >= * cand2_rot @ 0 >= * IF
      active_piece_type @ temp_type !
      temp_backup_type @ active_piece_type !
      cand2_x @ temp_px !
      cand2_y @ temp_py !
      cand2_z @ temp_pz !
      cand2_rot @ apply-ai-rotation
      
      // Update properties and grid block-by-block (set to 0)
      cand2_x @ active_dx0 @ + cand2_y @ active_dy0 @ + cand2_z @ active_dz0 @ + 0 update-properties-for-block-change
      cand2_x @ active_dx1 @ + cand2_y @ active_dy1 @ + cand2_z @ active_dz1 @ + 0 update-properties-for-block-change
      cand2_x @ active_dx2 @ + cand2_y @ active_dy2 @ + cand2_z @ active_dz2 @ + 0 update-properties-for-block-change
      cand2_x @ active_dx3 @ + cand2_y @ active_dy3 @ + cand2_z @ active_dz3 @ + 0 update-properties-for-block-change
      
      // Update plane counts
      cand2_z @ active_dz0 @ + plane-count-@ 1 - cand2_z @ active_dz0 @ + plane-count-!
      cand2_z @ active_dz1 @ + plane-count-@ 1 - cand2_z @ active_dz1 @ + plane-count-!
      cand2_z @ active_dz2 @ + plane-count-@ 1 - cand2_z @ active_dz2 @ + plane-count-!
      cand2_z @ active_dz3 @ + plane-count-@ 1 - cand2_z @ active_dz3 @ + plane-count-!
      
      0 set-sim-piece-in-grid
      temp_type @ active_piece_type !
      init-active-piece-offsets
    THEN
    0 sim_cand2_active !
  THEN
;

: is-cell-filled-simulated // ( x y z -- bool )
  grid-get 0 >
;

// Count holes in grid
: count-grid-holes // ( -- holes )
  0 temp_holes !
  0 temp_y !
  BEGIN temp_y @ grid_d @ < WHILE
    0 temp_x !
    BEGIN temp_x @ grid_w @ < WHILE
      0 temp_found_filled !
      grid_h @ 1 - temp_z !
      BEGIN temp_z @ 0 >= WHILE
        temp_x @ temp_y @ temp_z @ is-cell-filled-simulated IF
          1 temp_found_filled !
        ELSE
          temp_found_filled @ IF
            temp_holes @ 1 + temp_holes !
          THEN
        THEN
        temp_z @ 1 - temp_z !
      REPEAT
      temp_x @ 1 + temp_x !
    REPEAT
    temp_y @ 1 + temp_y !
  REPEAT
  temp_holes @
;

// Count completed lines/planes
: count-completed-lines // ( -- completed_planes )
  0 temp_completed !
  0 temp_z !
  BEGIN temp_z @ grid_h @ < WHILE
    1 temp_full !
    0 temp_y !
    BEGIN temp_y @ grid_d @ < WHILE
      0 temp_x !
      BEGIN temp_x @ grid_w @ < WHILE
        temp_x @ temp_y @ temp_z @ is-cell-filled-simulated 0 == IF
          0 temp_full !
        THEN
        temp_x @ 1 + temp_x !
      REPEAT
      temp_y @ 1 + temp_y !
    REPEAT
    temp_full @ IF
      temp_completed @ 1 + temp_completed !
    THEN
    temp_z @ 1 + temp_z !
  REPEAT
  temp_completed @
;

: count-grid-properties // ( -- height_sum bumpiness )
  0 temp_height_sum !
  0 temp_bumpiness !
  
  // 1. Compute and store heights
  0 temp_y !
  BEGIN temp_y @ grid_d @ < WHILE
    0 temp_x !
    BEGIN temp_x @ grid_w @ < WHILE
      0 temp_col_h !
      grid_h @ 1 - temp_z !
      0 temp_prop_found !
      BEGIN temp_z @ 0 >= temp_prop_found @ 0 == * WHILE
        temp_x @ temp_y @ temp_z @ is-cell-filled-simulated IF
          temp_z @ 1 + temp_col_h !
          1 temp_prop_found !
        THEN
        temp_z @ 1 - temp_z !
      REPEAT
      
      // Store in scratch memory: y * grid_w + x + 20000
      temp_col_h @
      temp_y @ grid_w @ * temp_x @ + 20000 + !
      
      temp_height_sum @ temp_col_h @ + temp_height_sum !
      temp_x @ 1 + temp_x !
    REPEAT
    temp_y @ 1 + temp_y !
  REPEAT
  
  // 2. Compute bumpiness (X-direction and Y-direction, including boundary transitions to height 0)
  0 temp_y !
  BEGIN temp_y @ grid_d @ < WHILE
    0 temp_x !
    BEGIN temp_x @ grid_w @ < WHILE
      
      // Height of current column
      temp_y @ grid_w @ * temp_x @ + 20000 + @ temp_col_h !
      
      // Compare with right neighbor (x + 1) or right wall
      temp_x @ 1 + grid_w @ < IF
        temp_col_h @
        temp_y @ grid_w @ * temp_x @ + 1 + 20000 + @ - abs
        temp_bumpiness @ + temp_bumpiness !
      ELSE
        temp_col_h @
        temp_bumpiness @ + temp_bumpiness !
      THEN
      
      // Compare with left wall (x == 0)
      temp_x @ 0 == IF
        temp_col_h @
        temp_bumpiness @ + temp_bumpiness !
      THEN
      
      // Compare with back neighbor (y + 1) or back wall
      temp_y @ 1 + grid_d @ < IF
        temp_col_h @
        temp_y @ 1 + grid_w @ * temp_x @ + 20000 + @ - abs
        temp_bumpiness @ + temp_bumpiness !
      ELSE
        temp_col_h @
        temp_bumpiness @ + temp_bumpiness !
      THEN
      
      // Compare with front wall (y == 0)
      temp_y @ 0 == IF
        temp_col_h @
        temp_bumpiness @ + temp_bumpiness !
      THEN
      
      temp_x @ 1 + temp_x !
    REPEAT
    temp_y @ 1 + temp_y !
  REPEAT
  
  temp_height_sum @
  temp_bumpiness @
;
: col-height-addr // ( x y -- addr )
  1 + swap 1 + swap
  grid_w @ 2 + * + grid_end_addr @ +
;

: col-height-@ // ( x y -- h )
  col-height-addr heap-@
;

: col-height-! // ( h x y -- )
  col-height-addr heap-!
;

: get-min-neighbor-height // ( x y -- min_neigh_h )
  temp_py !
  temp_px !
  
  999999 temp_min_h !
  
  // Left neighbor
  temp_px @ 1 - 0 >= IF
    temp_px @ 1 - temp_py @ col-height-@ temp_min_h @ min temp_min_h !
  THEN
  
  // Right neighbor
  temp_px @ 1 + grid_w @ < IF
    temp_px @ 1 + temp_py @ col-height-@ temp_min_h @ min temp_min_h !
  THEN
  
  // Forward/Back neighbor in 3D
  grid_d @ 1 > IF
    temp_py @ 1 - 0 >= IF
      temp_px @ temp_py @ 1 - col-height-@ temp_min_h @ min temp_min_h !
    THEN
    temp_py @ 1 + grid_d @ < IF
      temp_px @ temp_py @ 1 + col-height-@ temp_min_h @ min temp_min_h !
    THEN
  THEN
  
  temp_min_h @
;

: plane-count-@ // ( z -- count )
  400 + @
;

: plane-count-! // ( count z -- )
  400 + !
;

: precompute-base-properties
  0 base_height_sum !
  0 base_holes !
  0 base_bumpiness !
  
  grid_w @ 2 / 1 - 0 max new_min_x !
  grid_w @ 2 / 1 + grid_w @ 1 - min new_max_x !
  grid_d @ 2 / 1 - 0 max new_min_y !
  grid_d @ 2 / 1 + grid_d @ 1 - min new_max_y !
  
  search_min_x @ precompute_min_x !
  search_max_x @ precompute_max_x !
  search_min_y @ precompute_min_y !
  search_max_y @ precompute_max_y !
  
  precompute_max_x @ precompute_min_x @ - 1 + precompute_span_x !
  precompute_max_y @ precompute_min_y @ - 1 + precompute_span_x @ * precompute_total_cols !
  
  // Initialize plane counts to 0
  0 temp_z !
  BEGIN temp_z @ grid_h @ < WHILE
    0 temp_z @ plane-count-!
    temp_z @ 1 + temp_z !
  REPEAT
  
  // Determine search Z scan height dynamically
  grid_max_h @
  sim_cand1_active @ IF
    cand1_z @ 4 + max
  THEN
  sim_cand2_active @ IF
    cand2_z @ 4 + max
  THEN
  grid_h @ 1 - min
  temp_scan_h !
  
  1 precompute_state !
  0 precompute_idx !
;

: tick-precompute
  0 temp_tick_cols !
  1000 temp_tick_limit ! // Process up to 1000 columns per tick asynchronously
  
  grid_w @ grid_d @ * temp_wd !
  
  BEGIN
    precompute_state @ 0 >
    temp_tick_cols @ temp_tick_limit @ < * WHILE
    
    precompute_state @ 1 == IF
      // Height/holes scan
      precompute_idx @ precompute_span_x @ mod precompute_min_x @ + temp_x !
      precompute_idx @ precompute_span_x @ / precompute_min_y @ + temp_y !
      
      0 temp_col_h !
      0 temp_found !
      0 temp_found_filled !
      
      force_full_scan @ IF
        temp_scan_h @
      ELSE
        temp_x @ temp_y @ col-height-@
      THEN
      temp_z !
      
      temp_z @ 0 > IF
        temp_z @ 1 - temp_wd @ *
        grid_w @ temp_y @ * +
        temp_x @ +
        20000 + temp_addr !
        
        temp_z @ 1 - temp_z !
        BEGIN temp_z @ 0 >= WHILE
          temp_addr @ heap-@ 0 > IF
            1 temp_found_filled !
            temp_found @ 0 == IF
              temp_z @ 1 + temp_col_h !
              1 temp_found !
            THEN
            temp_z @ plane-count-@ 1 + temp_z @ plane-count-!
          ELSE
            temp_found_filled @ IF
              base_holes @ 1 + base_holes !
            THEN
          THEN
          temp_addr @ temp_wd @ - temp_addr !
          temp_z @ 1 - temp_z !
        REPEAT
      THEN
      
      temp_col_h @ temp_x @ temp_y @ col-height-!
      
      temp_col_h @ 0 > IF
        temp_x @ 2 - 0 max new_min_x @ min new_min_x !
        temp_x @ 2 + grid_w @ 1 - min new_max_x @ max new_max_x !
        temp_y @ 2 - 0 max new_min_y @ min new_min_y !
        temp_y @ 2 + grid_d @ 1 - min new_max_y @ max new_max_y !
      THEN
      
      base_height_sum @ temp_col_h @ + base_height_sum !
      
      precompute_idx @ 1 + precompute_idx !
      precompute_idx @ precompute_total_cols @ >= IF
        // Finished height/holes scan
        0 max_possible_clears !
        0 temp_z !
        BEGIN temp_z @ grid_h @ < WHILE
          temp_z @ plane-count-@
          grid_w @ grid_d @ * 4 - >= IF
            max_possible_clears @ 1 + max_possible_clears !
          THEN
          temp_z @ 1 + temp_z !
        REPEAT
        
        // Copy new bounding box back
        new_min_x @ search_min_x !
        new_max_x @ search_max_x !
        new_min_y @ search_min_y !
        new_max_y @ search_max_y !
        
        // Setup bumpiness bounding box
        search_min_x @ 1 - 0 max bump_min_x !
        search_max_x @ bump_max_x !
        search_min_y @ 1 - 0 max bump_min_y !
        search_max_y @ bump_max_y !
        
        bump_max_x @ bump_min_x @ - 1 + bump_span_x !
        bump_max_y @ bump_min_y @ - 1 + bump_span_x @ * bump_total_cols !
        
        // Transition to bumpiness scan
        2 precompute_state !
        0 precompute_idx !
      THEN
      
    ELSE
    precompute_state @ 2 == IF
      // Bumpiness scan
      precompute_idx @ bump_span_x @ mod bump_min_x @ + temp_x !
      precompute_idx @ bump_span_x @ / bump_min_y @ + temp_y !
      
      temp_x @ temp_y @ col-height-@ temp_col_h !
      
      // Right neighbor
      temp_x @ 1 + grid_w @ < IF
        temp_col_h @ temp_x @ 1 + temp_y @ col-height-@ - abs
        base_bumpiness @ + base_bumpiness !
      THEN
      
      // Back neighbor
      temp_y @ 1 + grid_d @ < IF
        temp_col_h @ temp_x @ temp_y @ 1 + col-height-@ - abs
        base_bumpiness @ + base_bumpiness !
      THEN
      
      precompute_idx @ 1 + precompute_idx !
      precompute_idx @ bump_total_cols @ >= IF
        // Finished bumpiness scan
        0 precompute_state !
        0 force_full_scan !
      THEN
    THEN THEN
    
    temp_tick_cols @ 1 + temp_tick_cols !
  REPEAT
;


: get-uc-old-h // ( idx -- old_h )
  dup 0 == IF
    pop uc0_x @ uc0_y @ col-height-@
  ELSE dup 1 == IF
    pop uc1_x @ uc1_y @ col-height-@
  ELSE dup 2 == IF
    pop uc2_x @ uc2_y @ col-height-@
  ELSE
    pop uc3_x @ uc3_y @ col-height-@
  THEN THEN THEN
;

: get-uc-new-h // ( idx -- new_h )
  dup 0 == IF
    pop uc0_x @ uc0_y @ col-height-@ uc0_max_z @ 1 + max
  ELSE dup 1 == IF
    pop uc1_x @ uc1_y @ col-height-@ uc1_max_z @ 1 + max
  ELSE dup 2 == IF
    pop uc2_x @ uc2_y @ col-height-@ uc2_max_z @ 1 + max
  ELSE
    pop uc3_x @ uc3_y @ col-height-@ uc3_max_z @ 1 + max
  THEN THEN THEN
;

: find-uc-index // ( nx ny -- is_uc idx )
  temp_py ! temp_px !
  
  temp_px @ uc0_x @ == temp_py @ uc0_y @ == * IF
    1 0
  ELSE num_uc @ 2 >= temp_px @ uc1_x @ == temp_py @ uc1_y @ == * * IF
    1 1
  ELSE num_uc @ 3 >= temp_px @ uc2_x @ == temp_py @ uc2_y @ == * * IF
    1 2
  ELSE num_uc @ 4 >= temp_px @ uc3_x @ == temp_py @ uc3_y @ == * * IF
    1 3
  ELSE
    0 0
  THEN THEN THEN THEN
;

: process-neighbor-edge
  temp_rank ! // pop 'i'
  temp_py ! // pop 'ny'
  temp_px ! // pop 'nx'
  temp_idx ! // pop 'idx'
  temp_found ! // pop 'is_uc'
  
  temp_found @ IF
    temp_rank @ temp_idx @ < IF
      temp_rank @ get-uc-old-h temp_col_h !
      temp_rank @ get-uc-new-h temp_z !
      
      temp_idx @ get-uc-old-h temp_scratch_h0 !
      temp_idx @ get-uc-new-h temp_scratch_h1 !
      
      temp_bumpiness @ temp_col_h @ temp_scratch_h0 @ - abs - temp_bumpiness !
      temp_bumpiness @ temp_z @ temp_scratch_h1 @ - abs + temp_bumpiness !
    THEN
  ELSE
    temp_px @ temp_py @ col-height-@ temp_x !
    
    temp_rank @ get-uc-old-h temp_col_h !
    temp_rank @ get-uc-new-h temp_z !
    
    temp_bumpiness @ temp_col_h @ temp_x @ - abs - temp_bumpiness !
    temp_bumpiness @ temp_z @ temp_x @ - abs + temp_bumpiness !
  THEN
;

: process-uc-neighbors // ( i -- )
  uc_neigh_idx !
  
  uc_neigh_idx @ 0 == IF
    uc0_x @ temp_x ! uc0_y @ temp_y !
  ELSE uc_neigh_idx @ 1 == IF
    uc1_x @ temp_x ! uc1_y @ temp_y !
  ELSE uc_neigh_idx @ 2 == IF
    uc2_x @ temp_x ! uc2_y @ temp_y !
  ELSE
    uc3_x @ temp_x ! uc3_y @ temp_y !
  THEN THEN THEN
  
  // Right neighbor
  temp_x @ 1 + grid_w @ < IF
    temp_x @ 1 + temp_y @ find-uc-index
    temp_x @ 1 + temp_y @
    uc_neigh_idx @
    process-neighbor-edge
  THEN
  
  // Left neighbor
  temp_x @ 1 - 0 >= IF
    temp_x @ 1 - temp_y @ find-uc-index
    temp_x @ 1 - temp_y @
    uc_neigh_idx @
    process-neighbor-edge
  THEN
  
  // Back neighbor
  temp_y @ 1 + grid_d @ < IF
    temp_x @ temp_y @ 1 + find-uc-index
    temp_x @ temp_y @ 1 +
    uc_neigh_idx @
    process-neighbor-edge
  THEN
  
  // Front neighbor
  temp_y @ 1 - 0 >= IF
    temp_x @ temp_y @ 1 - find-uc-index
    temp_x @ temp_y @ 1 -
    uc_neigh_idx @
    process-neighbor-edge
  THEN
;

: should-skip-column? // ( x y -- bool )
  temp_py !
  temp_px !
  
  temp_px @ temp_py @ col-height-@ 0 == IF
    temp_px @ 1 + temp_py @ col-height-@ 0 ==
    temp_px @ 1 - temp_py @ col-height-@ 0 == *
    temp_px @ temp_py @ 1 + col-height-@ 0 == *
    temp_px @ temp_py @ 1 - col-height-@ 0 == * IF
      grid_w @ 2 / temp_px @ - abs 1 >
      grid_d @ 2 / temp_py @ - abs 1 > + IF
        1
      ELSE
        0
      THEN
    ELSE
      0
    THEN
  ELSE
    0
  THEN
;

: should-skip-rotation? // ( rot type -- bool )
  temp_type !
  4 mod temp_z_rot !
  
  temp_type @ 1 == IF
    temp_z_rot @ 0 >
  ELSE
  temp_type @ 0 ==
  temp_type @ 5 == +
  temp_type @ 6 == + IF
    temp_z_rot @ 2 >=
  ELSE
    0
  THEN THEN
;

: run-ai-search-init
  999999 cand1_score !
  999999 cand2_score !
  999999 cand1_next_score !
  999999 cand2_next_score !
  -1 cand1_x ! -1 cand1_y ! -1 cand1_z ! -1 cand1_rot !
  -1 cand2_x ! -1 cand2_y ! -1 cand2_z ! -1 cand2_rot !
  0 ai_best_z !
  999999 search_best_score !
  1 ai_search_state !
;

: run-ai-search-finish
;

: run-ai-search-step
  active_grid_id @ 0 gl-grid-run-search
  cand1_score @ 999999 < IF
    active_grid_id @ 1 gl-grid-run-search
    search_best_score @ cand1_next_score !
  ELSE
    999999 cand1_next_score !
  THEN
  cand2_score @ 999999 < IF
    active_grid_id @ 2 gl-grid-run-search
    search_best_score @ cand2_next_score !
  ELSE
    999999 cand2_next_score !
  THEN
  cand1_score @ cand1_next_score @ +
  cand2_score @ cand2_next_score @ +
  <= IF
    cand1_x @ ai_best_x !
    cand1_y @ ai_best_y !
    cand1_z @ ai_best_z !
    cand1_rot @ ai_best_rot !
    cand1_score @ cand1_next_score @ + ai_best_score !
  ELSE
    cand2_x @ ai_best_x !
    cand2_y @ ai_best_y !
    cand2_z @ ai_best_z !
    cand2_rot @ ai_best_rot !
    cand2_score @ cand2_next_score @ + ai_best_score !
  THEN
  0 ai_search_state !
;

: run-ai-search
  run-ai-search-init
  run-ai-search-step
;

: trigger-ai-move
  ai_mode @ 1 == IF
    grid_h @ 1 - active_piece_z !
    999999 ai_best_score !
    run-ai-search-init
  THEN
;

: ai-play-tick
  1 ai_played !
  ai_search_state @ 1 == IF
    run-ai-search-step
    
    ai_search_state @ 0 == IF
      init-active-piece-offsets
      grid_d @ 1 > IF
        ai_best_rot @ 4 / ai_target_axis !
        ai_best_rot @ 4 mod ai_target_z_rot !
      ELSE
        0 ai_target_axis !
        ai_best_rot @ ai_target_z_rot !
      THEN
      0 ai_current_axis_done !
      0 ai_current_z_rot_done !
      0 ai_move_cooldown !
    THEN
  THEN

  ai_best_score @ 999999 < IF
    ai_move_cooldown @ 0 > IF
      ai_move_cooldown @ 1 - ai_move_cooldown !
    ELSE
      
      // Determine targets for movement
      ai_best_x @ temp_tx !
      ai_best_y @ temp_ty !
      
      // Check if straight vertical path is blocked by an overhang
      // Apply target rotation first to check collision/landing accurately, backing up and restoring active piece offsets
      active_dx0 @ ai_backup_dx0 ! active_dy0 @ ai_backup_dy0 ! active_dz0 @ ai_backup_dz0 !
      active_dx1 @ ai_backup_dx1 ! active_dy1 @ ai_backup_dy1 ! active_dz1 @ ai_backup_dz1 !
      active_dx2 @ ai_backup_dx2 ! active_dy2 @ ai_backup_dy2 ! active_dz2 @ ai_backup_dz2 !
      active_dx3 @ ai_backup_dx3 ! active_dy3 @ ai_backup_dy3 ! active_dz3 @ ai_backup_dz3 !
      
      ai_best_rot @ apply-ai-rotation
      ai_best_x @ ai_best_y @ find-landing-z temp_lz !
      
      temp_lz @ ai_best_z @ > IF
        // Overhang exists! Find clear adjacent column
        0 temp_found !
        
        // Check Left (ai_best_x - 1)
        ai_best_x @ 1 - 0 >= IF
          ai_best_x @ 1 - ai_best_y @ find-landing-z ai_best_z @ <= IF
            ai_best_x @ 1 - temp_tx !
            1 temp_found !
          THEN
        THEN
        
        // Check Right (ai_best_x + 1)
        temp_found @ 0 == IF
          ai_best_x @ 1 + grid_w @ < IF
            ai_best_x @ 1 + ai_best_y @ find-landing-z ai_best_z @ <= IF
              ai_best_x @ 1 + temp_tx !
              1 temp_found !
            THEN
          THEN
        THEN
        
        // Check Forward (ai_best_y - 1) in 3D
        grid_d @ 1 > IF
          temp_found @ 0 == IF
            ai_best_y @ 1 - 0 >= IF
              ai_best_x @ ai_best_y @ 1 - find-landing-z ai_best_z @ <= IF
                ai_best_y @ 1 - temp_ty !
                1 temp_found !
              THEN
            THEN
          THEN
          
          // Check Backward (ai_best_y + 1) in 3D
          temp_found @ 0 == IF
            ai_best_y @ 1 + grid_d @ < IF
              ai_best_x @ ai_best_y @ 1 + find-landing-z ai_best_z @ <= IF
                ai_best_y @ 1 + temp_ty !
                1 temp_found !
              THEN
            THEN
          THEN
        THEN
      THEN
      
      ai_backup_dx0 @ active_dx0 ! ai_backup_dy0 @ active_dy0 ! ai_backup_dz0 @ active_dz0 !
      ai_backup_dx1 @ active_dx1 ! ai_backup_dy1 @ active_dy1 ! ai_backup_dz1 @ active_dz1 !
      ai_backup_dx2 @ active_dx2 ! ai_backup_dy2 @ active_dy2 ! ai_backup_dz2 @ active_dz2 !
      ai_backup_dx3 @ active_dx3 ! ai_backup_dy3 @ active_dy3 ! ai_backup_dz3 @ active_dz3 !
      
      active_piece_z @ ai_best_z @ > IF
        // Still above target height: align to the clear adjacent column
        temp_tx @ temp_target_x !
        temp_ty @ temp_target_y !
      ELSE
        // At or below target height: slide into final X and Y
        ai_best_x @ temp_target_x !
        ai_best_y @ temp_target_y !
      THEN
      
      // 1. Rotation alignment first (at spawn height to avoid wall/block collisions)
      ai_current_axis_done @ 0 == IF
        ai_target_axis @ 1 == IF
          rotate-x-plus
          temp_rot_success @ IF
            1 ai_current_axis_done !
          THEN
        ELSE
        ai_target_axis @ 2 == IF
          rotate-y-plus
          temp_rot_success @ IF
            1 ai_current_axis_done !
          THEN
        ELSE
          1 ai_current_axis_done !
        THEN THEN
        7 ai_move_cooldown !
      ELSE
      ai_current_z_rot_done @ ai_target_z_rot @ < IF
        rotate-z-plus
        temp_rot_success @ IF
          ai_current_z_rot_done @ 1 + ai_current_z_rot_done !
        THEN
        7 ai_move_cooldown !
      ELSE
        
        // 2. Position alignment
        // Align X
        active_piece_x @ temp_target_x @ < IF
          move-right
          7 ai_move_cooldown !
        ELSE
        active_piece_x @ temp_target_x @ > IF
          move-left
          7 ai_move_cooldown !
        ELSE
          
          // Align Y
          active_piece_y @ temp_target_y @ < IF
            move-forward
            7 ai_move_cooldown !
          ELSE
          active_piece_y @ temp_target_y @ > IF
            move-backward
            7 ai_move_cooldown !
          ELSE
            
            // 3. Drop / slide logic
            active_piece_z @ ai_best_z @ > IF
              move-down pop
              2 ai_move_cooldown !
            ELSE
              // At ai_best_z: X/Y alignment must now slide to final target.
              // If it's already at ai_best_x/y, it will lock.
              active_piece_x @ ai_best_x @ ==
              active_piece_y @ ai_best_y @ == * IF
                move-down pop
                2 ai_move_cooldown !
              THEN
            THEN
            
          THEN THEN
        THEN THEN
      THEN THEN
    THEN
  THEN
;

: config-send
  temp_d ! temp_h ! temp_w !
  "/stackem_config " temp_w @ to-str + " " + temp_h @ to-str + " " + temp_d @ to-str + " " + enable_tetracubes @ to-str + send-line
;

// Z-Up to Y-Up translation wrapper for draw-model
: draw-model-zup
  temp_zup_frame !
  temp_zup_rz !
  temp_zup_ry !
  temp_zup_rx !
  temp_zup_z3d !
  temp_zup_y3d !
  temp_zup_x3d !
  temp_zup_mesh !

  temp_zup_mesh @
  temp_zup_x3d @
  temp_zup_z3d @
  0 temp_zup_y3d @ -
  temp_zup_rx @
  temp_zup_rz @
  temp_zup_ry @
  temp_zup_frame @
  draw-model
;

