  "tetromino_8" "{\"type\":\"voxel\",\"parts\":[{\"xMin\":-0.75,\"xMax\":0.25,\"yMin\":-1.0,\"yMax\":0.0,\"zMin\":-0.75,\"zMax\":0.25,\"color\":\"#88ccee\"},{\"xMin\":0.25,\"xMax\":1.25,\"yMin\":-1.0,\"yMax\":0.0,\"zMin\":-0.75,\"zMax\":0.25,\"color\":\"#88ccee\"},{\"xMin\":-0.75,\"xMax\":0.25,\"yMin\":0.0,\"yMax\":1.0,\"zMin\":-0.75,\"zMax\":0.25,\"color\":\"#88ccee\"},{\"xMin\":-0.75,\"xMax\":0.25,\"yMin\":0.0,\"yMax\":1.0,\"zMin\":0.25,\"zMax\":1.25,\"color\":\"#88ccee\"}]}" load-model

  "tetromino_9" "{\"type\":\"voxel\",\"parts\":[{\"xMin\":-0.75,\"xMax\":0.25,\"yMin\":-1.0,\"yMax\":0.0,\"zMin\":-0.75,\"zMax\":0.25,\"color\":\"#dddddd\"},{\"xMin\":0.25,\"xMax\":1.25,\"yMin\":-1.0,\"yMax\":0.0,\"zMin\":-0.75,\"zMax\":0.25,\"color\":\"#dddddd\"},{\"xMin\":-0.75,\"xMax\":0.25,\"yMin\":0.0,\"yMax\":1.0,\"zMin\":-0.75,\"zMax\":0.25,\"color\":\"#dddddd\"},{\"xMin\":-0.75,\"xMax\":0.25,\"yMin\":0.0,\"yMax\":1.0,\"zMin\":-1.75,\"zMax\":-0.75,\"color\":\"#dddddd\"}]}" load-model
;

// Calculate required rows/planes to clear at level L (10 for level 1, +15% per additional level)
: get-required-rows-for-level // ( level -- required )
  temp_req !
  10 // Start with 10 for level 1
  1 temp_rank !
  BEGIN temp_rank @ temp_req @ < WHILE
    dup dup 15 * 100 + * 100 /
    temp_rank @ 1 + temp_rank !
  REPEAT
;

// Reset game state and set initial active/next tetrominoes when gameplay starts
: init-game
  0 score !
  1 game_level !
  0 cleared_rows_at_level !
  600 9 game_level @ + / fall_speed !
  0 game_over !
  0 fall_timer !
  1 current_wave_lines !
  init-grid
  0 grid_max_h !
  1 force_full_scan !
  grid_w @ 2 / 1 - 0 max search_min_x !
  grid_w @ 2 / 1 + grid_w @ 1 - min search_max_x !
  grid_d @ 2 / 1 - 0 max search_min_y !
  grid_d @ 2 / 1 + grid_d @ 1 - min search_max_y !
  0 precompute_state !

  
  global_seed @ next-prng-val global_seed !
  global_seed @ get-random-piece-count mod active_piece_type !
  0 active_piece_rot !
  randomize-starting-pos
  init-active-piece-offsets
  ai_mode @ 0 == IF
    apply-random-rotations
  THEN
  
  global_seed @ next-prng-val global_seed !
  global_seed @ get-random-piece-count mod next_piece_type !
  0 ai_search_state !
  0 ai_played !
  trigger-ai-move
;

// --- Variables Initialization ---

: init-vars
  init_flag @ 0 == IF
    1 init_flag ! // Init flag = 1
    1 show_grid ! // Show grid = 1
    0 anim_cycle ! // Animation cycle counter = 0
    0 camera_auto_rotate ! // Auto camera rotation = 0
    0 camera_angle ! // Camera rotation angle = 0 degrees (default yaw)
    0 camera_pitch ! // Camera pitch = 0 degrees (default pitch)
    0 camera_focus_y ! // Camera focus Y = 0 (centered)
    0 camera_mode !
    3 auto_rot_speed !
    
    [GRID_W] grid_w !
    [GRID_H] grid_h !
    [GRID_D] grid_d !
    [ENABLE_TETRACUBES] enable_tetracubes !
    
    // Dynamically calculate camera distance based on grid size so the entire well fits closer
    grid_h @ 1 + camera_dist !
    0 game_started !
    1 game_level !
    0 cleared_rows_at_level !
    [LEADERBOARD_POPUP_OPEN] leaderboard_popup_open !
    [LEADERBOARD_ACTIVE_INDEX] dropdown_selected_idx !
    0 dropdown_open_state !
    -1 clearing_plane_z !
    0 clearing_timer !
    -1 last_seen_replay_frame !
    1 current_wave_lines !
    
    init-grid
    init-voxel-models
    
    // Seed the global PRNG
    anim_cycle @ 17 + 1 max global_seed !
    
    // Randomize initial shapes
    global_seed @ next-prng-val global_seed !
    global_seed @ get-random-piece-count mod active_piece_type !
    0 active_piece_rot !
    randomize-starting-pos
    
    init-active-piece-offsets
    ai_mode @ 0 == IF
      apply-random-rotations
    THEN
    
    global_seed @ next-prng-val global_seed !
    global_seed @ get-random-piece-count mod next_piece_type !
    
    600 9 game_level @ + / fall_speed ! // Fall speed = drops/sec formula
    0 fall_timer ! // Fall timer = 0
    0 score ! // Score = 0
    [START_GAME_OVER] game_over ! // Game Over state placeholder
    
    // Server highscore placeholder (replaced on handshake compilation)
    [HIGHSCORE] highscore !
    
    0 cooldown_left ! // Cooldown left
    0 cooldown_right ! // Cooldown right
    0 cooldown_rotate ! // Cooldown rotate
    0 cooldown_soft_drop ! // Cooldown soft drop
    0 cooldown_hard_drop !
    0 cooldown_z !
    0 cooldown_f2 !
    0 cooldown_menu_keys !
    0 auto_drop_active !
    0 lock_delay_timer !
    0 fall_timer !

    // Initialize keyboard mapping defaults
    87 bind_forward !
    65 bind_left !
    68 bind_right !
    83 bind_backward !
    81 bind_rot_z_l !
    69 bind_rot_z_r !
    82 bind_rot_x_f !
    70 bind_rot_x_b !
    90 bind_rot_y_l !
    67 bind_rot_y_r !
    88 bind_down !
    32 bind_drop !
    0 bind_waiting !
    0 customizing_keys !
    0 last_mouse_x !
    0 last_mouse_y !
    0 mouse_dragging !
    0 ai_mode !
    0 cooldown_f3 !
    0 ai_move_cooldown !
    0 ai_search_state !
    0 ai_played !
    grid_w @ 2 / 1 - 0 max search_min_x !
    grid_w @ 2 / 1 + grid_w @ 1 - min search_max_x !
    grid_d @ 2 / 1 - 0 max search_min_y !
    grid_d @ 2 / 1 + grid_d @ 1 - min search_max_y !
    0 precompute_state !
    trigger-ai-move
  THEN
;

: get-camera-quadrant
  camera_angle @ 360 + 360 mod temp_ang !
  temp_ang @ 45 >= temp_ang @ 135 < * IF 1 ELSE
  temp_ang @ 135 >= temp_ang @ 225 < * IF 2 ELSE
  temp_ang @ 225 >= temp_ang @ 315 < * IF 3 ELSE
  0
  THEN THEN THEN
;

: move-cam-left
  get-camera-quadrant dup 0 == IF pop move-left ELSE
  dup 1 == IF pop move-backward ELSE
  dup 2 == IF pop move-right ELSE
  pop move-forward
  THEN THEN THEN
;

: move-cam-right
  get-camera-quadrant dup 0 == IF pop move-right ELSE
  dup 1 == IF pop move-forward ELSE
  dup 2 == IF pop move-left ELSE
  pop move-backward
  THEN THEN THEN
;

: move-cam-forward
  get-camera-quadrant dup 0 == IF pop move-forward ELSE
  dup 1 == IF pop move-left ELSE
  dup 2 == IF pop move-backward ELSE
  pop move-right
  THEN THEN THEN
;

: move-cam-backward
  get-camera-quadrant dup 0 == IF pop move-backward ELSE
  dup 1 == IF pop move-right ELSE
  dup 2 == IF pop move-forward ELSE
  pop move-left
  THEN THEN THEN
;

// --- Key Remap Helpers ---

: key-name // ( keycode -- str )
  dup 32 == IF pop "SPACE" ELSE
  dup 65 == IF pop "A" ELSE
  dup 66 == IF pop "B" ELSE
  dup 67 == IF pop "C" ELSE
  dup 68 == IF pop "D" ELSE
  dup 69 == IF pop "E" ELSE
  dup 70 == IF pop "F" ELSE
  dup 71 == IF pop "G" ELSE
  dup 72 == IF pop "H" ELSE
  dup 73 == IF pop "I" ELSE
  dup 74 == IF pop "J" ELSE
  dup 75 == IF pop "K" ELSE
  dup 76 == IF pop "L" ELSE
  dup 77 == IF pop "M" ELSE
  dup 78 == IF pop "N" ELSE
  dup 79 == IF pop "O" ELSE
  dup 80 == IF pop "P" ELSE
  dup 81 == IF pop "Q" ELSE
  dup 82 == IF pop "R" ELSE
  dup 83 == IF pop "S" ELSE
  dup 84 == IF pop "T" ELSE
  dup 85 == IF pop "U" ELSE
  dup 86 == IF pop "V" ELSE
  dup 87 == IF pop "W" ELSE
  dup 88 == IF pop "X" ELSE
  dup 89 == IF pop "Y" ELSE
  dup 90 == IF pop "Z" ELSE
  dup 262 == IF pop "RIGHT" ELSE
  dup 263 == IF pop "LEFT" ELSE
  dup 264 == IF pop "DOWN" ELSE
  dup 265 == IF pop "UP" ELSE
  dup 320 == IF pop "KP 0" ELSE
  dup 321 == IF pop "KP 1" ELSE
  dup 322 == IF pop "KP 2" ELSE
  dup 323 == IF pop "KP 3" ELSE
  dup 324 == IF pop "KP 4" ELSE
  dup 325 == IF pop "KP 5" ELSE
  dup 326 == IF pop "KP 6" ELSE
  dup 327 == IF pop "KP 7" ELSE
  dup 328 == IF pop "KP 8" ELSE
  dup 329 == IF pop "KP 9" ELSE
  to-str
  THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN
  THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN
  THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN
  THEN THEN THEN THEN THEN
;

: start-key-capture // ( bind_id -- )
  dup bind_waiting !
  client-capture-key
;

#force-inclusion
: on-key-captured // ( bind_id keycode -- )
  swap // ( keycode bind_id -- )
  dup 1 == IF over bind_forward ! THEN
  dup 2 == IF over bind_left ! THEN
  dup 3 == IF over bind_right ! THEN
  dup 4 == IF over bind_backward ! THEN
  dup 5 == IF over bind_rot_z_l ! THEN
  dup 6 == IF over bind_rot_z_r ! THEN
  dup 7 == IF over bind_rot_x_f ! THEN
  dup 8 == IF over bind_rot_x_b ! THEN
  dup 9 == IF over bind_rot_y_l ! THEN
  dup 10 == IF over bind_rot_y_r ! THEN
  dup 11 == IF over bind_down ! THEN
  dup 12 == IF over bind_drop ! THEN
  pop pop
  0 bind_waiting !
;

: check-menu-keys
  cooldown_f2 @ 0 > IF cooldown_f2 @ 1 - cooldown_f2 ! THEN
  cooldown_f3 @ 0 > IF cooldown_f3 @ 1 - cooldown_f3 ! THEN
  cooldown_menu_keys @ 0 > IF cooldown_menu_keys @ 1 - cooldown_menu_keys ! THEN
  
  // 1. Check F2 key (GLFW_KEY_F2 = 291)
  291 key-down? IF
    leaderboard_popup_open @ 0 == IF
      cooldown_f2 @ 0 == IF
        1 game_started !
        0 ai_mode !
        init-game
        0 leaderboard_popup_open !
        0 customizing_keys !
        15 cooldown_f2 !
      THEN
    THEN
  ELSE
    0 cooldown_f2 !
  THEN

  // 1.1. Check F3 key (GLFW_KEY_F3 = 292)
  292 key-down? IF
    leaderboard_popup_open @ 0 == IF
      cooldown_f3 @ 0 == IF
        1 game_started !
        1 ai_mode !
        init-game
        0 leaderboard_popup_open !
        0 customizing_keys !
        15 cooldown_f3 !
      THEN
    THEN
  ELSE
    0 cooldown_f3 !
  THEN

  // 2. Check H (72) or L (76) for showing/hiding leaderboard
  72 key-down? 76 key-down? + IF
    cooldown_menu_keys @ 0 == IF
      leaderboard_popup_open @ 1 == IF
        0 leaderboard_popup_open !
        0 dropdown_open_state !
      ELSE
        1 leaderboard_popup_open !
      THEN
      15 cooldown_menu_keys !
    THEN
  ELSE
    0 cooldown_menu_keys !
  THEN
;

// --- Gameplay Input & Timers ---

: handle-camera-input
  // Drag camera logic: Right-click drag (both axes) or Left-click drag (pitch only, viewport only)
  mouse-pos temp_mb ! temp_my ! temp_mx !
  
  0 temp_is_dragging !
  
  // Right-click is held (anywhere)
  temp_mb @ 2 / 2 mod 1 == IF
    1 temp_is_dragging !
  ELSE
    // Left-click is held in viewport (leaderboard closed)
    temp_mb @ 2 mod 1 ==
    leaderboard_popup_open @ 0 == *
    temp_mx @ 430 > *
    temp_mx @ 1170 < * IF
      2 temp_is_dragging !
    THEN
  THEN
  
  temp_is_dragging @ 0 > IF
    mouse_dragging @ 1 == IF
      temp_mx @ last_mouse_x @ - temp_dx !
      temp_my @ last_mouse_y @ - temp_dy !
      
      temp_is_dragging @ 1 == IF
        // Right-click drag (yaw & pitch)
        camera_angle @ temp_dx @ - 360 mod camera_angle !
        camera_pitch @ temp_dy @ - -90 max 90 min camera_pitch !
      ELSE
        // Left-click drag (sliding focal height up/down - double speed)
        camera_focus_y @ temp_dy @ 2 * +
        grid_h @ 1 - 50 *
        dup 0 swap -
        rot max min
        camera_focus_y !
      THEN
    THEN
    1 mouse_dragging !
    temp_mx @ last_mouse_x !
    temp_my @ last_mouse_y !
  ELSE
    0 mouse_dragging !
  THEN

  // --- CAMERA CONTROLS (Right side of keyboard) ---
  
  // 7 - move camera focal point up (stop at top of well)
  327 key-down? 55 key-down? + IF
    camera_focus_y @ 15 +
    grid_h @ 1 - 50 *
    dup 0 swap -
    rot max min
    camera_focus_y !
  THEN
  // 1 - move camera focal point down (stop at bottom of well)
  321 key-down? 49 key-down? + IF
    camera_focus_y @ 15 -
    grid_h @ 1 - 50 *
    dup 0 swap -
    rot max min
    camera_focus_y !
  THEN
  // 8 - move camera back and downward (stop at antizenith = -90)
  328 key-down? 56 key-down? + IF
    camera_pitch @ 2 - -90 max camera_pitch !
  THEN
  // 2 - move camera up and forward (stop at zenith = 90)
  322 key-down? 50 key-down? + IF
    camera_pitch @ 2 + 90 min camera_pitch !
  THEN
  // 4 - revolve left
  324 key-down? 52 key-down? + IF
    camera_angle @ 2 - 360 mod camera_angle !
  THEN
  // 6 - revolve right
  326 key-down? 54 key-down? + IF
    camera_angle @ 2 + 360 mod camera_angle !
  THEN
  // - - decrease camera distance (zoom in, stop at 8)
  45 key-down? 333 key-down? + IF
    camera_dist @ 8 > IF camera_dist @ 1 - camera_dist ! THEN
  THEN
  // + - increase camera distance (zoom out, stop at 60)
  61 key-down? 334 key-down? + IF
    camera_dist @ 60 < IF camera_dist @ 1 + camera_dist ! THEN
  THEN
;

: handle-gameplay-input
  // Decrement cooldown counters
  cooldown_left @ 0 > IF cooldown_left @ 1 - cooldown_left ! THEN
  cooldown_right @ 0 > IF cooldown_right @ 1 - cooldown_right ! THEN
  cooldown_rotate @ 0 > IF cooldown_rotate @ 1 - cooldown_rotate ! THEN
  cooldown_soft_drop @ 0 > IF cooldown_soft_drop @ 1 - cooldown_soft_drop ! THEN
  cooldown_hard_drop @ 0 > IF cooldown_hard_drop @ 1 - cooldown_hard_drop ! THEN
  cooldown_z @ 0 > IF cooldown_z @ 1 - cooldown_z ! THEN

  // --- GAMEPLAY CONTROLS (Left side/Remapped keys) ---

  // Move Left
  bind_left @ key-down? IF
    cooldown_left @ 0 == IF
      move-cam-left
      7 cooldown_left !
    THEN
  ELSE
    0 cooldown_left !
  THEN
  
  // Move Right
  bind_right @ key-down? IF
    cooldown_right @ 0 == IF
      move-cam-right
      7 cooldown_right !
    THEN
  ELSE
    0 cooldown_right !
  THEN
  
  // Move Forward / Backward (Z axis depth)
  bind_forward @ key-down? IF
    cooldown_z @ 0 == IF
      move-cam-forward
      7 cooldown_z !
    THEN
  ELSE
    bind_backward @ key-down? IF
      cooldown_z @ 0 == IF
        move-cam-backward
        7 cooldown_z !
      THEN
    ELSE
      0 cooldown_z !
    THEN
  THEN

  // Rotations
  cooldown_rotate @ 0 == IF
    // Z rotate left
    bind_rot_z_l @ key-down? IF
      rotate-z-plus 7 cooldown_rotate !
    ELSE
      // Z rotate right
      bind_rot_z_r @ key-down? IF
        rotate-z-minus 7 cooldown_rotate !
      ELSE
        // X rotate forward
        bind_rot_x_f @ key-down? IF
          rotate-x-plus 7 cooldown_rotate !
        ELSE
          // X rotate backward
          bind_rot_x_b @ key-down? IF
            rotate-x-minus 7 cooldown_rotate !
          ELSE
            // Y rotate left
            bind_rot_y_l @ key-down? IF
              rotate-y-plus 7 cooldown_rotate !
            ELSE
              // Y rotate right
              bind_rot_y_r @ key-down? IF
                rotate-y-minus 7 cooldown_rotate !
              THEN
            THEN
          THEN
        THEN
      THEN
    THEN
  THEN
  
  // Move Down (soft drop)
  bind_down @ key-down? IF
    cooldown_soft_drop @ 0 == IF
      move-down pop
      2 cooldown_soft_drop !
    THEN
  ELSE
    0 cooldown_soft_drop !
  THEN

  // Auto Drop (hard drop)
  bind_drop @ key-down? IF
    cooldown_hard_drop @ 0 == IF
      1 auto_drop_active !
      30 cooldown_hard_drop !
    THEN
  ELSE
    0 cooldown_hard_drop !
  THEN
;

: update-fall
  auto_drop_active @ 1 == IF
    // Check if colliding below
    active_piece_x @ active_piece_y @ active_piece_z @ 1 - 0 check-collision-at 1 == IF
      // Colliding (landed)
      lock_delay_timer @ 1 + lock_delay_timer !
      lock_delay_timer @ 10 >= IF
        0 lock_delay_timer !
        0 auto_drop_active !
        move-down pop
      THEN
    ELSE
      // Not colliding (falling)
      0 lock_delay_timer !
      fall_timer @ 1 + fall_timer !
      fall_timer @ 2 >= IF
        0 fall_timer !
        move-down pop
      THEN
    THEN
  ELSE
    fall_timer @ 1 + fall_timer !
    fall_timer @ fall_speed @ >= IF
      0 fall_timer !
      move-down pop
    THEN
  THEN
;

// --- Rendering Routines ---

// Z-Up to Y-Up translation wrapper for draw-mesh
: draw-mesh-zup
  temp_zup_rz !
  temp_zup_ry !
  temp_zup_rx !
  temp_zup_z3d !
  temp_zup_y3d !
  temp_zup_x3d !
  temp_zup_mesh !

  temp_zup_mesh @
  temp_zup_x3d @
  temp_zup_z3d @
  0 temp_zup_y3d @ -
  temp_zup_rx @
  temp_zup_rz @
  temp_zup_ry @
  draw-mesh
;

// Camera positioning
: setup-camera
  // Camera transform: x y z pitch yaw roll
  0 camera_focus_y @ camera_dist @ camera_pitch @ camera_angle @ 0 set-camera
;

// Draw a single block in the 3D space
// ( x y z color_idx -- )
: draw-block-3d
  temp_draw_color ! // color_idx
  temp_draw_z ! // z
  temp_draw_y ! // y
  temp_draw_x ! // x

  // Center coordinates around (0,0,0) in 3D (scaled by 100 for precision)
  temp_draw_x @ 100 * grid_w @ 1 - 50 * - temp_draw_x3d !
  temp_draw_y @ 100 * grid_d @ 1 - 50 * - temp_draw_y3d !
  temp_draw_z @ 100 * grid_h @ 1 - 50 * - temp_draw_z3d !

  // Map index to color mesh reference
  temp_draw_color @ 1 == IF "cube_red" ELSE
  temp_draw_color @ 2 == IF "cube_orange" ELSE
  temp_draw_color @ 3 == IF "cube_green" ELSE
  temp_draw_color @ 4 == IF "cube_blue" ELSE
  temp_draw_color @ 5 == IF "cube_purple" ELSE
  temp_draw_color @ 6 == IF "cube_pink" ELSE
  temp_draw_color @ 7 == IF "cube_brown" ELSE
  temp_draw_color @ 8 == IF "cube_magenta" ELSE
  temp_draw_color @ 9 == IF "cube_cyan" ELSE
  "cube_yellow"
  THEN THEN THEN THEN THEN THEN THEN THEN THEN

  temp_draw_x3d @ temp_draw_y3d @ temp_draw_z3d @ 0 0 0 draw-mesh-zup
;

// Draw the static locked board in 3D
: draw-grid-3d
  grid_w @ grid_h @ grid_d @ draw-grid
;

// Calculate lowest Z coordinate the piece can fall to
: find-ghost-z // ( -- ghost_z )
  active_piece_z @ temp_ghost_z !
  BEGIN
    active_piece_x @ active_piece_y @ temp_ghost_z @ 1 - 0 check-collision-at 0 ==
  WHILE
    temp_ghost_z @ 1 - temp_ghost_z !
  REPEAT
  temp_ghost_z @
;

// Draw a single ghost block in 3D space
// ( x y z color_idx -- )
: draw-ghost-block-3d
  temp_draw_color ! // color_idx
  temp_draw_z ! // z
  temp_draw_y ! // y
  temp_draw_x ! // x

  // Center coordinates around (0,0,0) in 3D (scaled by 100 for precision)
  temp_draw_x @ 100 * grid_w @ 1 - 50 * - temp_draw_x3d !
  temp_draw_y @ 100 * grid_d @ 1 - 50 * - temp_draw_y3d !
  temp_draw_z @ 100 * grid_h @ 1 - 50 * - temp_draw_z3d !

  // Map index to ghost color mesh reference
  temp_draw_color @ 1 == IF "cube_ghost_red" ELSE
  temp_draw_color @ 2 == IF "cube_ghost_orange" ELSE
  temp_draw_color @ 3 == IF "cube_ghost_green" ELSE
  temp_draw_color @ 4 == IF "cube_ghost_blue" ELSE
  temp_draw_color @ 5 == IF "cube_ghost_purple" ELSE
  temp_draw_color @ 6 == IF "cube_ghost_pink" ELSE
  temp_draw_color @ 7 == IF "cube_ghost_brown" ELSE
  temp_draw_color @ 8 == IF "cube_ghost_magenta" ELSE
  temp_draw_color @ 9 == IF "cube_ghost_cyan" ELSE
  "cube_ghost_yellow"
  THEN THEN THEN THEN THEN THEN THEN THEN THEN

  temp_draw_x3d @ temp_draw_y3d @ temp_draw_z3d @ 0 0 0 draw-mesh-zup
;

// Draw the landing ghost tetromino in 3D
: draw-ghost-piece-3d
  find-ghost-z temp_ghost_z !
  // Draw only if the ghost position is below the active piece
  temp_ghost_z @ active_piece_z @ < IF
    active_piece_x @ active_dx0 @ + active_piece_y @ active_dy0 @ + temp_ghost_z @ active_dz0 @ + active_piece_type @ 1 + draw-ghost-block-3d
    active_piece_x @ active_dx1 @ + active_piece_y @ active_dy1 @ + temp_ghost_z @ active_dz1 @ + active_piece_type @ 1 + draw-ghost-block-3d
    active_piece_x @ active_dx2 @ + active_piece_y @ active_dy2 @ + temp_ghost_z @ active_dz2 @ + active_piece_type @ 1 + draw-ghost-block-3d
    active_piece_x @ active_dx3 @ + active_piece_y @ active_dy3 @ + temp_ghost_z @ active_dz3 @ + active_piece_type @ 1 + draw-ghost-block-3d
  THEN
;

// Draw the active dropping tetromino in 3D
: draw-active-piece-3d
  active_piece_x @ active_dx0 @ + active_piece_y @ active_dy0 @ + active_piece_z @ active_dz0 @ + active_piece_type @ 1 + draw-block-3d
  active_piece_x @ active_dx1 @ + active_piece_y @ active_dy1 @ + active_piece_z @ active_dz1 @ + active_piece_type @ 1 + draw-block-3d
  active_piece_x @ active_dx2 @ + active_piece_y @ active_dy2 @ + active_piece_z @ active_dz2 @ + active_piece_type @ 1 + draw-block-3d
  active_piece_x @ active_dx3 @ + active_piece_y @ active_dy3 @ + active_piece_z @ active_dz3 @ + active_piece_type @ 1 + draw-block-3d
;

// Draw left/right columns and bottom board edge to frame the Tetris matrix in 3D
: draw-frame-3d
  grid_w @ grid_h @ grid_d @ draw-frame
;

: get-cos-sin // ( idx -- cos_x100 sin_x100 )
  dup 0 == IF pop 100 0 ELSE
  dup 1 == IF pop 97 26 ELSE
  dup 2 == IF pop 87 50 ELSE
  dup 3 == IF pop 71 71 ELSE
  dup 4 == IF pop 50 87 ELSE
  dup 5 == IF pop 26 97 ELSE
  dup 6 == IF pop 0 100 ELSE
  dup 7 == IF pop -26 97 ELSE
  dup 8 == IF pop -50 87 ELSE
  dup 9 == IF pop -71 71 ELSE
  dup 10 == IF pop -87 50 ELSE
  dup 11 == IF pop -97 26 ELSE
  dup 12 == IF pop -100 0 ELSE
  dup 13 == IF pop -97 -26 ELSE
  dup 14 == IF pop -87 -50 ELSE
  dup 15 == IF pop -71 -71 ELSE
  dup 16 == IF pop -50 -87 ELSE
  dup 17 == IF pop -26 -97 ELSE
  dup 18 == IF pop 0 -100 ELSE
  dup 19 == IF pop 26 -97 ELSE
  dup 20 == IF pop 50 -87 ELSE
  dup 21 == IF pop 71 -71 ELSE
  dup 22 == IF pop 87 -50 ELSE
  dup 23 == IF pop 97 -26 ELSE
  pop 100 0
  THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN
  THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN THEN
;

// Rotate coordinate dx around Y-axis into dx_rot and dz_rot using 24-angle lookup (15-degree steps)
// ( dx angle -- dx_rot dz_rot )
: rotate-x-z
  get-cos-sin
  temp_sin !
  temp_cos !
  
  dup
  temp_cos @ *
  swap
  temp_sin @ *
  0 swap -
;

: deg-to-idx // ( deg -- idx )
  360 + 360 mod 15 / 24 mod
;

// Rotate (x, z) by degrees around Y axis (both scaled by 100)
// ( x_scaled z_scaled deg -- x_rot_scaled z_rot_scaled )
: rotate-point-y
  deg-to-idx get-cos-sin
  temp_sin !
  temp_cos !
  temp_draw_z3d ! // z_scaled
  temp_draw_x3d ! // x_scaled
  
  // x_rot = (x * cos - z * sin) / 100
  temp_draw_x3d @ temp_cos @ *
  temp_draw_z3d @ temp_sin @ * -
  100 /
  
  // z_rot = (x * sin + z * cos) / 100
  temp_draw_x3d @ temp_sin @ *
  temp_draw_z3d @ temp_cos @ * +
  100 /
;

/// Float the next upcoming shape in 3D space on the right side of the screen
: draw-next-piece-3d
  "tetromino_" next_piece_type @ to-str +
  1325 // x_3d (width, scaled, centered in the UI panel horizontally)
  0    // y_3d (depth, scaled)
  -795 // z_3d (height, scaled, centered in the UI panel space vertically)
  0 // rx
  0 anim_cycle @ 3 * - 360 mod // ry
  -20 // rz
  0 // frame
  draw-model-zup
;

: get-slider-track // ( speed -- str )
  dup 1 == IF pop "[|---------]" ELSE
  dup 2 == IF pop "[-|--------]" ELSE
  dup 3 == IF pop "[--|-------]" ELSE
  dup 4 == IF pop "[---|------]" ELSE
  dup 5 == IF pop "[----|-----]" ELSE
  dup 6 == IF pop "[-----|----]" ELSE
  dup 7 == IF pop "[------|---]" ELSE
  dup 8 == IF pop "[-------|--]" ELSE
  dup 9 == IF pop "[--------|-]" ELSE
  pop "[---------|]"
  THEN THEN THEN THEN THEN THEN THEN THEN THEN
;

// --- Interface/GUI Routines ---

: draw-gui
  is_replaying @ 1 == IF
    // Render Replay HUD
    30 150 400 680 "Replay Controller" ui-panel
    
    // Render Next Piece Panel (Right Side)
    1170 660 400 170 "UPCOMING PIECE" ui-panel
    
    60 220 "title" "REPLAYING GAME" ui-text
    60 260 "yellow" "Player: [PLAYERNAME]" ui-text
    60 300 "accent" "Score: " score @ to-str + ui-text
    60 345 "yellow" "Level: " game_level @ to-str + ui-text
    
    60 400 "yellow" "Speed: " ui-text
    replay_speed_pct @ 100 == IF 60 425 "green" "1.00x" ui-text THEN
    replay_speed_pct @ 50 == IF 60 425 "yellow" "0.50x" ui-text THEN
    replay_speed_pct @ 25 == IF 60 425 "yellow" "0.25x" ui-text THEN
    replay_speed_pct @ 75 == IF 60 425 "yellow" "0.75x" ui-text THEN
    replay_speed_pct @ 100 > IF
      60 425 "accent" replay_speed_pct @ 100 / to-str ".00x" + ui-text
    THEN
    
    60 470 140 35 "Slower" ui-button IF
      replay_speed_pct @ 100 <= IF
        replay_speed_pct @ 25 > IF replay_speed_pct @ 25 - replay_speed_pct ! THEN
      ELSE
        replay_speed_pct @ 100 - replay_speed_pct !
      THEN
    THEN
    220 470 140 35 "Faster" ui-button IF
      replay_speed_pct @ 100 < IF
        replay_speed_pct @ 25 + replay_speed_pct !
      ELSE
        replay_speed_pct @ 1000 < IF replay_speed_pct @ 100 + replay_speed_pct ! THEN
      THEN
    THEN
    60 520 300 35 replay_paused @ 1 == IF "Play / Resume" ELSE "Pause Replay" THEN ui-button IF
      replay_paused @ 1 == IF 0 replay_paused ! ELSE 1 replay_paused ! THEN
    THEN
    
    60 570 140 35 "< Step Back" replay_paused @ 0 == ui-button-disabled IF
      replay_frame_index @ 1 - 0 max replay_frame_index !
      1 replay_step_request !
    THEN
    220 570 140 35 "Step Forth >" replay_paused @ 0 == ui-button-disabled IF
      replay_frame_index @ 1 + replay_frame_index !
      1 replay_step_request !
    THEN
    
    60 640 300 45 "Exit Replay" ui-button IF
      "/stackem_exit_replay" send-line
    THEN
    
    60 700 300 45 "Restart Replay" ui-button IF
      0 replay_frame_index !
      1 replay_step_request !
    THEN
    
    60 760 300 25 replay_total_frames @ 0 == IF 0 ELSE replay_frame_index @ 100 * replay_total_frames @ / 100 min 0 max THEN "Frame: " replay_frame_index @ to-str + " / " + replay_total_frames @ to-str + ui-progress-bar
  ELSE
    game_started @ 0 == IF
    // Render setup/config panel
    30 150 400 680 "Stack 'em - Game Setup" ui-panel
    
    60 220 "title" "STACK 'EM (3D TETRIS)" ui-text
    60 260 "yellow" "Player: [PLAYERNAME]" ui-text
    
    60 310 "accent" "CONFIGURE GRID SIZE:" ui-text
    
    60 350 35 25 "-" ui-button IF
      grid_w @ 1 - 4 max grid_w !
      init-grid
      grid_w @ grid_h @ grid_d @ config-send
    THEN
    105 350 35 25 "+" ui-button IF
      grid_w @ 1 + 25 min grid_w !
      init-grid
      grid_w @ grid_h @ grid_d @ config-send
    THEN
    155 353 "yellow" "Width (X): " grid_w @ to-str + ui-text
    
    60 390 35 25 "-" ui-button IF
      grid_h @ 1 - 10 max grid_h !
      init-grid
      grid_w @ grid_h @ grid_d @ config-send
    THEN
    105 390 35 25 "+" ui-button IF
      grid_h @ 1 + 25 min grid_h !
      init-grid
      grid_w @ grid_h @ grid_d @ config-send
    THEN
    155 393 "yellow" "Height (Z): " grid_h @ to-str + ui-text
    
    60 430 35 25 "-" ui-button IF
      grid_d @ 1 - 1 max grid_d !
      init-grid
      grid_w @ grid_h @ grid_d @ config-send
    THEN
    105 430 35 25 "+" ui-button IF
      grid_d @ 1 + 25 min grid_d !
      init-grid
      grid_w @ grid_h @ grid_d @ config-send
    THEN
    155 433 "yellow" "Depth (Y): " grid_d @ to-str + ui-text
    
    60 470 110 25 "Toggle 3D" ui-button IF
      enable_tetracubes @ IF 0 ELSE 1 THEN enable_tetracubes !
    THEN
    185 473 "yellow" "3D/2D Mode: " enable_tetracubes @ IF "ON" ELSE "OFF" THEN + ui-text
    
    // START GAME button!
    60 515 300 45 "New Game [F2]" ui-button IF
      1 game_started !
      0 ai_mode !
      init-game
    THEN

    // START AI GAME button!
    60 570 300 45 "New AI Game [F3]" ui-button IF
      1 game_started !
      1 ai_mode !
      init-game
    THEN

    // Back to main menu
    60 635 300 35 "Return to Main Menu" ui-button IF
      "/play menu" send-line
    THEN
    
    60 680 300 35 "View Leaderboards" ui-button IF
      1 leaderboard_popup_open !
    THEN
  ELSE
    // 1. Stats and Score Deck Panel (Left)
    30 150 400 680 "Stack 'em - Score Deck" ui-panel
    
    60 205 "title" "STACK 'EM (3D TETRIS)" ui-text
    60 240 "yellow" "Player: [PLAYERNAME]" ui-text
    60 275 "accent" "Score: " score @ to-str + ui-text
    60 310 "green" "High Score: " highscore @ to-str + ui-text
    60 345 "yellow" "Level: " game_level @ to-str + ui-text
    60 375 "yellow" "Progress: " cleared_rows_at_level @ to-str + " / " + game_level @ get-required-rows-for-level to-str + ui-text
    
    
    game_over @ 1 == IF
      60 400 "red" "GAME OVER!" ui-text
      60 430 "yellow" "Final Score: " score @ to-str + ui-text
      
      // Restart game button
      60 480 300 35 "Restart Game" ui-button IF
        init-game
      THEN
      
      // Return to config button
      60 535 300 35 "Setup New Game" ui-button IF
        0 game_started !
      THEN
      
      // Return to menu
      60 590 300 35 "Return to Main Menu" ui-button IF
        "/play menu" send-line
      THEN
      
      60 645 300 35 "View Leaderboard" ui-button IF
        1 leaderboard_popup_open !
      THEN
    ELSE
      60 400 300 35
      ai_mode @ 1 == IF "AI Mode: ON [Playing]" ELSE "AI Mode: OFF" THEN
      ui-button IF
        ai_mode @ 1 == IF
          0 ai_mode !
          0 auto_drop_active !
          ai_search_state @ 1 == IF
            0 ai_search_state !
            run-ai-search-finish
          THEN
        ELSE
          1 ai_mode !
          trigger-ai-move
        THEN
      THEN
      
      ai_mode @ 1 == IF
        60 445 "magenta" "STATUS: AI ACTIVE" ui-text
      ELSE
        60 445 "green" "STATUS: ACTIVE" ui-text
      THEN
      
      60 480 "accent" "CONTROLS:" ui-text
      60 510 "yellow" "Move Forward: " bind_forward @ key-name + ui-text
      60 535 "yellow" "Move Left: " bind_left @ key-name + ui-text
      60 560 "yellow" "Move Right: " bind_right @ key-name + ui-text
      60 585 "yellow" "Move Backward: " bind_backward @ key-name + ui-text
      60 610 "yellow" "Rotate Z: " bind_rot_z_l @ key-name + " / " + bind_rot_z_r @ key-name + ui-text
      60 635 "yellow" "Rotate X: " bind_rot_x_f @ key-name + " / " + bind_rot_x_b @ key-name + ui-text
      60 660 "yellow" "Rotate Y: " bind_rot_y_l @ key-name + " / " + bind_rot_y_r @ key-name + ui-text
      60 685 "yellow" "Soft Drop: " bind_down @ key-name + ui-text
      60 710 "yellow" "Hard Drop: " bind_drop @ key-name + ui-text
    THEN
  THEN
  customizing_keys @ 1 == IF
    // 2. Keyboard Customization Panel (Right)
    1170 150 400 680 "Configure Controls" ui-panel
    
    1200 200 "title" "KEYBOARD CONFIGURATION" ui-text
    
    // Row 1: Move Forward
    1200 240 "yellow" "Forward:" ui-text
    bind_waiting @ 1 == IF
      1330 240 "red" "PRESS KEY..." ui-text
    ELSE
      1330 240 "green" bind_forward @ key-name ui-text
      1430 235 100 25 "Change" ui-button IF 1 start-key-capture THEN
    THEN
    
    // Row 2: Move Left
    1200 270 "yellow" "Left:" ui-text
    bind_waiting @ 2 == IF
      1330 270 "red" "PRESS KEY..." ui-text
    ELSE
      1330 270 "green" bind_left @ key-name ui-text
      1430 265 100 25 "Change" ui-button IF 2 start-key-capture THEN
    THEN
    
    // Row 3: Move Right
    1200 300 "yellow" "Right:" ui-text
    bind_waiting @ 3 == IF
      1330 300 "red" "PRESS KEY..." ui-text
    ELSE
      1330 300 "green" bind_right @ key-name ui-text
      1430 295 100 25 "Change" ui-button IF 3 start-key-capture THEN
    THEN
    
    // Row 4: Move Backward
    1200 330 "yellow" "Backward:" ui-text
    bind_waiting @ 4 == IF
      1330 330 "red" "PRESS KEY..." ui-text
    ELSE
      1330 330 "green" bind_backward @ key-name ui-text
      1430 325 100 25 "Change" ui-button IF 4 start-key-capture THEN
    THEN
    
    // Row 5: Rot Z Left
    1200 360 "yellow" "Rotate Z L:" ui-text
    bind_waiting @ 5 == IF
      1330 360 "red" "PRESS KEY..." ui-text
    ELSE
      1330 360 "green" bind_rot_z_l @ key-name ui-text
      1430 355 100 25 "Change" ui-button IF 5 start-key-capture THEN
    THEN
    
    // Row 6: Rot Z Right
    1200 390 "yellow" "Rotate Z R:" ui-text
    bind_waiting @ 6 == IF
      1330 390 "red" "PRESS KEY..." ui-text
    ELSE
      1330 390 "green" bind_rot_z_r @ key-name ui-text
      1430 385 100 25 "Change" ui-button IF 6 start-key-capture THEN
    THEN
    
    // Row 7: Rot X Forward
    1200 420 "yellow" "Rotate X F:" ui-text
    bind_waiting @ 7 == IF
      1330 420 "red" "PRESS KEY..." ui-text
    ELSE
      1330 420 "green" bind_rot_x_f @ key-name ui-text
      1430 415 100 25 "Change" ui-button IF 7 start-key-capture THEN
    THEN
    
    // Row 8: Rot X Backward
    1200 450 "yellow" "Rotate X B:" ui-text
    bind_waiting @ 8 == IF
      1330 450 "red" "PRESS KEY..." ui-text
    ELSE
      1330 450 "green" bind_rot_x_b @ key-name ui-text
      1430 445 100 25 "Change" ui-button IF 8 start-key-capture THEN
    THEN
    
    // Row 9: Rot Y Left
    1200 480 "yellow" "Rotate Y L:" ui-text
    bind_waiting @ 9 == IF
      1330 480 "red" "PRESS KEY..." ui-text
    ELSE
      1330 480 "green" bind_rot_y_l @ key-name ui-text
      1430 475 100 25 "Change" ui-button IF 9 start-key-capture THEN
    THEN
    
    // Row 10: Rot Y Right
    1200 510 "yellow" "Rotate Y R:" ui-text
    bind_waiting @ 10 == IF
      1330 510 "red" "PRESS KEY..." ui-text
    ELSE
      1330 510 "green" bind_rot_y_r @ key-name ui-text
      1430 505 100 25 "Change" ui-button IF 10 start-key-capture THEN
    THEN
    
    // Row 11: Move Down
    1200 540 "yellow" "Move Down:" ui-text
    bind_waiting @ 11 == IF
      1330 540 "red" "PRESS KEY..." ui-text
    ELSE
      1330 540 "green" bind_down @ key-name ui-text
      1430 535 100 25 "Change" ui-button IF 11 start-key-capture THEN
    THEN
    
    // Row 12: Auto Drop
    1200 570 "yellow" "Auto Drop:" ui-text
    bind_waiting @ 12 == IF
      1330 570 "red" "PRESS KEY..." ui-text
    ELSE
      1330 570 "green" bind_drop @ key-name ui-text
      1430 565 100 25 "Change" ui-button IF 12 start-key-capture THEN
    THEN
    
    1200 610 340 35 "Done & Save" ui-button IF
      0 customizing_keys !
    THEN
    
    1200 665 "accent" "Camera keys: Numpad 8/2/4/6, +/-" ui-text
  ELSE
    // 2. Control and camera deck panel (Right)
      1170 150 400 680 "Camera & Game Controls" ui-panel
      
      1200 220 "title" "BOARD CONTROLS" ui-text
      
      // Panning buttons
      1200 300 160 35 "Rotate Left" ui-button IF
        camera_angle @ 5 - 360 mod camera_angle !
      THEN
      1380 300 160 35 "Rotate Right" ui-button IF
        camera_angle @ 5 + 360 mod camera_angle !
      THEN
      
      1200 350 160 35 "Pitch Up" ui-button IF
        camera_pitch @ 5 + 90 min camera_pitch !
      THEN
      1380 350 160 35 "Pitch Down" ui-button IF
        camera_pitch @ 5 - -90 max camera_pitch !
      THEN
      
      1200 400 340 35 "Reset Camera View" ui-button IF
        0 camera_angle !
        0 camera_pitch !
      THEN
      
      1200 450 340 35 "Toggle Auto-Rotation" ui-button IF
        camera_auto_rotate @ 1 == IF 0 camera_auto_rotate ! ELSE 1 camera_auto_rotate ! THEN
      THEN
      
      camera_auto_rotate @ 1 == IF
        1200 495 "green" "Auto-Rotation: ACTIVE" ui-text
        
        // Speed label
        1200 525 "yellow" "Speed: " auto_rot_speed @ to-str + " RPM" + ui-text
        
        // Slider track
        1340 525 "accent" auto_rot_speed @ get-slider-track ui-text
        
        // Drag track detection
        mouse-pos temp_mb ! temp_my ! temp_mx !
        temp_mb @ 2 mod 1 == IF
          temp_mx @ 1340 >= temp_mx @ 1483 <= * IF
            temp_my @ 515 >= temp_my @ 545 <= * IF
              temp_mx @ 1340 - 14 / 1 + 1 max 10 min auto_rot_speed !
            THEN
          THEN
        THEN
      ELSE
        1200 495 "red" "Auto-Rotation: INACTIVE" ui-text
      THEN
      
      1200 565 340 35 "Toggle Camera Mode" ui-button IF
        camera_mode @ 0 == IF 1 camera_mode ! ELSE 0 camera_mode ! THEN
      THEN
      
      camera_mode @ 0 == IF
        1200 610 "green" "Camera Mode: LOCKED (ORBIT)" ui-text
      ELSE
        1200 610 "yellow" "Camera Mode: TRIPOD (FREE)" ui-text
      THEN
      
      // Keyboard configuration launcher button
      1200 640 340 35 "Configure Keyboard Keys" ui-button IF
        1 customizing_keys !
      THEN
      
      // Next piece label
      1200 690 "yellow" "UPCOMING PIECE:" ui-text
      
      1200 800 "accent" "Press Esc to Go Back" ui-text
  THEN

  leaderboard_popup_open @ 1 == IF
    500 150 600 680 "High Score Leaderboard" ui-panel
    
    530 220 540 35 "Category" "[LEADERBOARD_CATEGORIES]" "dark" 1 dropdown_selected_idx dropdown_open_state ui-dropdown IF
      "/stackem_leaderboard_idx " swap to-str + send-line
    ELSE
      pop
    THEN
    
    1 temp_rank !
    BEGIN temp_rank @ 11 < WHILE
      temp_rank @ get-leaderboard-name temp_draw_x !
      temp_rank @ get-leaderboard-score to-str temp_draw_y !
      temp_rank @ get-leaderboard-has-rec temp_draw_has_rec !
      
      temp_draw_x @ "" == IF
        // empty slot
      ELSE
        530 240 temp_rank @ 30 * + "yellow" temp_rank @ to-str ". " + temp_draw_x @ + " : " + temp_draw_y @ + ui-text
        
        // Replay button or "no recording available" text
        temp_draw_has_rec @ 1 == IF
          800 240 temp_rank @ 30 * + 3 - 65 25 "Replay" ui-button IF
            "/stackem_request_replay " temp_rank @ to-str + send-line
          THEN
        ELSE
          800 240 temp_rank @ 30 * + "dark" "no recording available" ui-text
        THEN
        
        // Delete button for Gods
        [IS_GOD] 1 == IF
          990 240 temp_rank @ 30 * + 3 - 25 25 "X" ui-button IF
            "/stackem_delete_entry " temp_rank @ to-str + send-line
          THEN
        THEN
      THEN
      temp_rank @ 1 + temp_rank !
    REPEAT
    
    [IS_GOD] 1 == IF
      699 800 "red" "Reset Leaderboard" ui-text
      
      // Check for click with cooldown
      cooldown_menu_keys @ 0 == IF
        mouse-pos temp_mb ! temp_my ! temp_mx !
        temp_mb @ 2 mod 1 == IF
          temp_mx @ 689 >= temp_mx @ 911 <= * IF
            temp_my @ 790 >= temp_my @ 825 <= * IF
              "/stackem_reset_leaderboard" send-line
              15 cooldown_menu_keys !
            THEN
          THEN
        THEN
      THEN
    THEN
    
    700 755 200 35 "Close" ui-button IF
      0 leaderboard_popup_open !
      0 dropdown_open_state !
    THEN
  THEN
  THEN
;

: check-camera-grid-change
  grid_w @ last_cam_grid_w @ == 0 ==
  grid_h @ last_cam_grid_h @ == 0 == +
  grid_d @ last_cam_grid_d @ == 0 == + IF
    // Recalculate camera distance dynamically to fit the grid closer
    grid_h @ 1 + camera_dist !
    
    // Reset camera orientation
    0 camera_angle !
    0 camera_pitch !
    
    // Store current dimensions
    grid_w @ last_cam_grid_w !
    grid_h @ last_cam_grid_h !
    grid_d @ last_cam_grid_d !
  THEN
;

// --- Main Program Entry Loop ---

: update-clearing-animation
  clearing_plane_z @ -1 > IF
    clearing_timer @ 1 + clearing_timer !
    
    // Tick 31: Disappear, drop blocks, and spawn the next piece
    clearing_timer @ 31 >= IF
      clearing_plane_z @ clear-and-shift-down
      
      // Update points/scores for 1 plane cleared
      grid_w @ grid_d @ *
      10 game_level @ + *
      current_wave_lines @ get-line-clear-multiplier *
      4 game_level @ + *
      40 /
      score @ + score !
      
      cleared_rows_at_level @ 1 + cleared_rows_at_level !
      
      // Level Up Check
      game_level @ get-required-rows-for-level temp_req !
      cleared_rows_at_level @ temp_req @ >= IF
        cleared_rows_at_level @ temp_req @ - cleared_rows_at_level !
        game_level @ 1 + game_level !
        600 9 game_level @ + / temp_speed !
        temp_speed @ 2 < IF 2 temp_speed ! THEN
        temp_speed @ fall_speed !
      THEN
      
      score @ highscore @ > IF
        score @ highscore !
        save-highscore
      THEN
      
      // Reset animation states
      -1 clearing_plane_z !
      0 clearing_timer !
      
      // Check if there are more lines/planes to clear
      check-lines
      
      // If we finished clearing all lines/planes, spawn the next piece!
      clearing_plane_z @ -1 == IF
        spawn-piece
      THEN
    THEN
  THEN
;

: main
  init-vars
  check-camera-grid-change
  check-menu-keys
  
  // Update cycle/animation counters
  anim_cycle @ 1 + 13000 mod anim_cycle !
  global_seed @ next-prng-val global_seed !
  
  // Handle panning camera
  camera_auto_rotate @ 1 == IF
    anim_cycle @ auto_rot_speed @ * 10 / 360 mod camera_angle !
  THEN
  
  // Handle camera input (orbit/zoom/drag) as long as we are not binding a key
  bind_waiting @ 0 == IF
    handle-camera-input
  THEN
  
  // Run main gameplay logic if game is started, not over, and not in key config menu
  game_started @ 1 == game_over @ 0 == * customizing_keys @ 0 == * leaderboard_popup_open @ 0 == * IF
    is_replaying @ 0 == IF
      clearing_plane_z @ -1 == IF
        ai_mode @ 1 == IF
          ai-play-tick
        ELSE
          handle-gameplay-input
        THEN
        update-fall
      ELSE
        update-clearing-animation
      THEN
    ELSE
      // During replay, only run the clearing animation if active, replay is not paused, and the frame index changed!
      clearing_plane_z @ -1 > replay_paused @ 0 == * IF
        replay_frame_index @ last_seen_replay_frame @ == 0 == IF
          update-clearing-animation
          replay_frame_index @ last_seen_replay_frame !
        THEN
      THEN
    THEN
  THEN

  
  // Render everything
  setup-camera
  draw-grid-3d
  game_started @ 1 == game_over @ 0 == * clearing_plane_z @ -1 == * IF
    draw-active-piece-3d
    draw-ghost-piece-3d
  THEN
  draw-frame-3d
  game_started @ 1 == game_over @ 0 == * customizing_keys @ 0 == * IF
    draw-next-piece-3d
  THEN
  draw-gui
;

